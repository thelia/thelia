#!/usr/bin/env php
<?php

declare(strict_types=1);

/*
 * Prepares a clean test database without booting the Symfony kernel.
 *
 * Usage:
 *   php bin/test-prepare
 *   ddev exec php bin/test-prepare
 */

$projectRoot = dirname(__DIR__).DIRECTORY_SEPARATOR;
if (!defined('DS')) {
    define('DS', DIRECTORY_SEPARATOR);
}
if (!defined('THELIA_ROOT')) {
    define('THELIA_ROOT', $projectRoot);
}
if (!defined('THELIA_VENDOR')) {
    define('THELIA_VENDOR', $projectRoot.'vendor'.DS);
}
if (!defined('THELIA_LIB')) {
    $coreAtRoot = $projectRoot.'core'.DS.'lib'.DS.'Thelia'.DS;
    define('THELIA_LIB', is_dir($coreAtRoot)
        ? $coreAtRoot
        : THELIA_VENDOR.'thelia'.DS.'core'.DS.'lib'.DS.'Thelia'.DS
    );
}

require $projectRoot.'vendor/autoload.php';

use Symfony\Component\Dotenv\Dotenv;
use Thelia\Install\Standalone\DatabaseSetup;

(new Dotenv())->bootEnv(dirname(__DIR__).'/.env');

$host     = $_SERVER['DATABASE_HOST'] ?? '';
$port     = $_SERVER['DATABASE_PORT'] ?? '3306';
$user     = $_SERVER['DATABASE_USER'] ?? '';
$password = $_SERVER['DATABASE_PASSWORD'] ?? '';
$dbName   = $_SERVER['DATABASE_NAME'] ?? '';

if ('' === $host || '' === $dbName) {
    fwrite(STDERR, "ERROR: DATABASE_HOST and DATABASE_NAME must be set.\n");
    exit(1);
}

if (!preg_match('/^[a-zA-Z0-9_\-]+$/', $dbName)) {
    fwrite(STDERR, "ERROR: DATABASE_NAME contains invalid characters: {$dbName}\n");
    exit(1);
}

try {
    $setup = new DatabaseSetup($host, $port, $dbName, $user, $password);

    echo "Creating database \"{$dbName}\"...\n";
    $setup->createDatabase();

    echo "Applying core schema...\n";
    $setup->connect();
    $setup->applyCoreSchemaAndSeed();

    echo "Registering modules...\n";
    $count = $setup->registerAndApplyModules();
    echo "  {$count} module(s) registered\n";

    foreach ($setup->getWarnings() as $warning) {
        fwrite(STDERR, "  WARN {$warning}\n");
    }

    ensureJwtKeyPair($projectRoot);

    echo "\nDone: database \"{$dbName}\" is ready.\n";
} catch (\PDOException $e) {
    fwrite(STDERR, "ERROR: Database connection failed — {$e->getMessage()}\n");
    exit(1);
}

/**
 * Generates a JWT key pair for the test environment if missing.
 *
 * The API Platform tests authenticate against /api/admin/login and
 * /api/front/login, which rely on LexikJWTAuthenticationBundle. Without
 * the keys the login endpoints return 500 and every API test fails in
 * an obscure way. Running the generator here keeps `bin/test-prepare`
 * the single entry point for a CI-ready environment.
 */
function ensureJwtKeyPair(string $projectRoot): void
{
    $privateKey = $projectRoot.'config'.DS.'jwt'.DS.'private.pem';
    $publicKey  = $projectRoot.'config'.DS.'jwt'.DS.'public.pem';

    if (is_file($privateKey) && is_file($publicKey)) {
        return;
    }

    echo "Generating JWT key pair (test environment)...\n";
    $console = $projectRoot.'bin'.DS.'console';
    $command = \sprintf(
        '%s %s lexik:jwt:generate-keypair --skip-if-exists --env=test 2>&1',
        escapeshellarg(PHP_BINARY),
        escapeshellarg($console),
    );

    exec($command, $output, $exitCode);

    if (0 !== $exitCode) {
        fwrite(STDERR, "  WARN JWT key pair generation failed:\n");
        foreach ($output as $line) {
            fwrite(STDERR, "    {$line}\n");
        }
    }
}
