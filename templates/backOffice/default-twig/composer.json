{
    "name": "thelia/backoffice-default-twig-template",
    "type": "thelia-backoffice-template",
    "description": "Thelia 3 back-office template based on Twig, Symfony UX and Bootstrap 5.",
    "license": "LGPL-3.0+",
    "keywords": [
        "thelia-backoffice-template",
        "thelia-twig",
        "thelia-bootstrap-5"
    ],
    "require": {
        "php": ">=8.3",
        "symfony/framework-bundle": "^7.4",
        "symfony/twig-bundle": "^7.4",
        "symfony/webpack-encore-bundle": "^2.1",
        "symfony/stimulus-bundle": "^2.19",
        "symfony/ux-twig-component": "^2.19",
        "symfony/ux-icons": "^2.21",
        "thelia/twig-engine-module": "dev-twig"
    },
    "autoload": {
        "psr-4": {
            "BackOfficeDefaultTwigBundle\\": "src/"
        }
    },
    "extra": {
        "installer-name": "default-twig"
    }
}
