{% set stats = this.stats %}

<div class="row g-4" data-testid="bo-dashboard">
    <div class="col-md-3 col-sm-6">
        <a href="{{ path('admin.customers') }}" class="text-decoration-none">
            <div class="card h-100 shadow-sm border-0" data-testid="dashboard-customers-card">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">{{ 'Customers'|trans }}</div>
                        <div class="h4 mb-0" data-testid="dashboard-customers-count">{{ stats.customersCount }}</div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3 col-sm-6">
        <a href="{{ path('admin.order.list') }}" class="text-decoration-none">
            <div class="card h-100 shadow-sm border-0" data-testid="dashboard-pending-orders-card">
                <div class="card-body d-flex align-items-center">
                    <div class="rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center me-3" style="width:48px;height:48px;">
                        <i class="bi bi-cart-check-fill fs-3"></i>
                    </div>
                    <div>
                        <div class="text-muted small">{{ 'Pending orders'|trans }}</div>
                        <div class="h4 mb-0" data-testid="dashboard-pending-orders-count">{{ stats.pendingOrdersCount }}</div>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col-md-3 col-sm-6">
        <div class="card h-100 shadow-sm border-0" data-testid="dashboard-recent-orders-card">
            <div class="card-header bg-body-tertiary d-flex align-items-center">
                <i class="bi bi-clock-history me-2 text-info"></i>
                <h2 class="h6 mb-0">{{ 'Recent orders'|trans }}</h2>
            </div>
            <ul class="list-group list-group-flush small">
                {% for order in stats.recentOrders %}
                    <li class="list-group-item d-flex justify-content-between align-items-center" data-testid="dashboard-recent-order-row">
                        <a href="{{ path('admin.order.update.view', {order_id: order.id}) }}" class="text-decoration-none text-truncate me-2">{{ order.ref }}</a>
                        <span class="badge text-bg-secondary">{{ order.totalAmount|number_format(2) }}&nbsp;{{ order.currency.symbol }}</span>
                    </li>
                {% else %}
                    <li class="list-group-item text-muted text-center">{{ 'No recent order'|trans }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>

    <div class="col-md-3 col-sm-6">
        <div class="card h-100 shadow-sm border-0" data-testid="dashboard-low-stock-card">
            <div class="card-header bg-body-tertiary d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>
                <h2 class="h6 mb-0">{{ 'Low stock'|trans }} <small class="text-muted">(&le;&nbsp;{{ stats.lowStockThreshold }})</small></h2>
            </div>
            <ul class="list-group list-group-flush small">
                {% for pse in stats.lowStockProducts %}
                    <li class="list-group-item d-flex justify-content-between align-items-center" data-testid="dashboard-low-stock-row">
                        <a href="{{ path('admin.products.update', {product_id: pse.productId}) }}" class="text-decoration-none text-truncate me-2" title="{{ pse.product.title }}">{{ pse.product.title|default(pse.ref) }}</a>
                        <span class="badge text-bg-danger">{{ pse.quantity }}</span>
                    </li>
                {% else %}
                    <li class="list-group-item text-muted text-center">{{ 'All products in stock'|trans }}</li>
                {% endfor %}
            </ul>
        </div>
    </div>
</div>
