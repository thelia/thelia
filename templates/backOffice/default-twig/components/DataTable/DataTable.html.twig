<div class="card" data-testid="datatable-{{ id }}">
    {% if caption %}
        <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">{{ caption }}</h2>
            <div class="datatable-toolbar">
                {% block toolbar %}{% endblock %}
            </div>
        </div>
    {% endif %}

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0" data-testid="datatable-{{ id }}-table">
            <thead class="table-light">
                <tr>
                    {% for column in columns %}
                        <th scope="col" class="text-{{ column.cellAlign }}">{{ column.label }}</th>
                    {% endfor %}
                </tr>
            </thead>
            <tbody{% for attr, value in tbodyAttributes %} {{ attr }}="{{ value }}"{% endfor %}>
                {% for row in rows %}
                    <tr data-testid="datatable-{{ id }}-row" data-row-id="{{ row.id|default('') }}">
                        {% for column in columns %}
                            <td class="text-{{ column.cellAlign }}" data-testid="datatable-{{ id }}-cell-{{ column.key }}">
                                {% include '@BackOfficeDefaultTwig/components/DataTable/cells/' ~ column.kind.value ~ '.html.twig' with {
                                    column: column,
                                    row: row,
                                    value: row[column.key]|default(null),
                                } only %}
                            </td>
                        {% endfor %}
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="{{ columns|length }}" class="text-center text-muted py-4" data-testid="datatable-{{ id }}-empty">
                            {{ emptyMessage|default('No data'|trans({}, 'bo.default-twig')) }}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
