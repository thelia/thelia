{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit folder'|trans }} — {{ folder.title }}{% endblock %}
{% block body_testid %}catalog-folder-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.folders.default') }}">{{ 'Library'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ folder.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('folder.top', { folder: folder.id }) }}

    <div class="container-fluid" data-testid="folder-edit-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Folder'|trans }} <small class="text-muted">#{{ folder.id }}</small></h1>
            <a href="{{ path('admin.folders.default', { folder_id: folder.parent }) }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'Back'|trans }}
            </a>
        </div>

        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'general' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-general" type="button" data-testid="folder-tab-general">
                    {{ 'General'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'children' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-children" type="button" data-testid="folder-tab-children">
                    {{ 'Subfolders'|trans }} <span class="badge bg-secondary">{{ children|length }}</span>
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade {% if current_tab == 'general' %}show active{% endif %}" id="tab-general" role="tabpanel">
                {{ form_start(form, { action: path('admin.folders.save', { folder_id: folder.id }), method: 'post', attr: { 'data-testid': 'folder-edit-form' } }) }}
                    <input type="hidden" name="folder_id" value="{{ folder.id }}">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                {{ form_label(form.title) }}
                                {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                                {{ form_errors(form.title) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.chapo) }}
                                {{ form_widget(form.chapo, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.description) }}
                                {{ form_widget(form.description, { attr: { class: 'form-control', rows: 8 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.postscriptum) }}
                                {{ form_widget(form.postscriptum, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mb-3">
                                {{ form_widget(form.visible, { attr: { class: 'form-check-input' } }) }}
                                {{ form_label(form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.parent) }}
                                {{ form_widget(form.parent, { attr: { class: 'form-control' } }) }}
                            </div>
                        </div>
                    </div>
                    {{ form_widget(form.id) }}
                    {{ form_widget(form.locale) }}
                    {{ safe_hook('folder.update-form', { folder: folder.id }) }}
                    <button type="submit" class="btn btn-primary" data-testid="folder-edit-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                    </button>
                {{ form_end(form) }}
            </div>

            <div class="tab-pane fade {% if current_tab == 'children' %}show active{% endif %}" id="tab-children" role="tabpanel">
                <a href="{{ path('admin.folders.default', { folder_id: folder.id }) }}" class="btn btn-outline-primary mb-3">
                    <i class="bi bi-list" aria-hidden="true"></i> {{ 'Manage subfolders'|trans }}
                </a>
                <table class="table" data-testid="folder-children-table">
                    <thead>
                        <tr>
                            <th>{{ 'Title'|trans }}</th>
                            <th class="text-center">{{ 'Online'|trans }}</th>
                            <th class="text-center">{{ 'Position'|trans }}</th>
                            <th class="text-end">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for child in children %}
                            <tr data-testid="folder-child-row-{{ child.id }}">
                                <td>{{ child.title }}</td>
                                <td class="text-center">{% if child.visible %}<i class="bi bi-check2 text-success"></i>{% else %}<i class="bi bi-x text-danger"></i>{% endif %}</td>
                                <td class="text-center">{{ child.position }}</td>
                                <td class="text-end">
                                    <a href="{{ child.edit_url }}" class="btn btn-sm btn-outline-secondary" data-testid="folder-child-edit-{{ child.id }}">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-muted text-center">{{ 'No subfolder.'|trans }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>
    </div>

    {{ safe_hook('folder.bottom', { folder: folder.id }) }}
{% endblock %}
