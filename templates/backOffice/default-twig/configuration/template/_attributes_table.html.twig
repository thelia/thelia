<table class="table mb-0" data-testid="template-attributes-table">
    <thead>
        <tr>
            <th>{{ 'Attribute'|trans }}</th>
            <th class="text-center">{{ 'Position'|trans }}</th>
            <th class="text-end">{{ 'Actions'|trans }}</th>
        </tr>
    </thead>
    <tbody data-controller="bo-sortable"
           data-bo-sortable-url-value="{{ attribute_position_url }}"
           data-bo-sortable-token-value="{{ position_token }}"
           data-bo-sortable-param-name-value="attribute_id"
           data-bo-sortable-extra-params-value='{"template_id": {{ template.id }}}'>
        {% for attribute in attributes %}
            <tr data-id="{{ attribute.id }}" data-testid="template-attribute-row-{{ attribute.id }}">
                <td>{{ attribute.title }}</td>
                <td class="text-center">{{ attribute.position }}</td>
                <td class="text-end">
                    <a href="{{ attribute.delete_url }}" class="btn btn-sm btn-outline-danger" data-testid="template-attribute-delete-{{ attribute.id }}" onclick="return confirm('{{ 'Remove this attribute from the template?'|trans }}')">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="3" class="text-muted text-center">{{ 'No attribute attached.'|trans }}</td></tr>
        {% endfor %}
    </tbody>
</table>
