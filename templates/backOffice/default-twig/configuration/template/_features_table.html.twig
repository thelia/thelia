<table class="table mb-0" data-testid="template-features-table">
    <thead>
        <tr>
            <th>{{ 'Feature'|trans }}</th>
            <th class="text-center">{{ 'Position'|trans }}</th>
            <th class="text-end">{{ 'Actions'|trans }}</th>
        </tr>
    </thead>
    <tbody data-controller="bo-sortable"
           data-bo-sortable-url-value="{{ feature_position_url }}"
           data-bo-sortable-token-value="{{ position_token }}"
           data-bo-sortable-param-name-value="feature_id"
           data-bo-sortable-extra-params-value='{"template_id": {{ template.id }}}'>
        {% for feature in features %}
            <tr data-id="{{ feature.id }}" data-testid="template-feature-row-{{ feature.id }}">
                <td>{{ feature.title }}</td>
                <td class="text-center">{{ feature.position }}</td>
                <td class="text-end">
                    <a href="{{ feature.delete_url }}" class="btn btn-sm btn-outline-danger" data-testid="template-feature-delete-{{ feature.id }}" onclick="return confirm('{{ 'Remove this feature from the template?'|trans }}')">
                        <i class="bi bi-trash" aria-hidden="true"></i>
                    </a>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="3" class="text-muted text-center">{{ 'No feature attached.'|trans }}</td></tr>
        {% endfor %}
    </tbody>
</table>
