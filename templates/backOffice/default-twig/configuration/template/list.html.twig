{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Product templates'|trans }}{% endblock %}
{% block body_testid %}configuration-templates{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Templates'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('templates.top') }}

    <div class="container-fluid" data-testid="templates-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Product templates'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.configuration.template') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#template-create-modal" data-testid="template-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    {{ 'Add a new template'|trans }}
                </button>
            {% endif %}
        </div>

        {{ component('BoDataTable', {
            id: 'templates',
            columns: [
                column('id', 'ID'|trans),
                column('name', 'Name'|trans),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No template defined yet.'|trans,
        }) }}
    </div>

    {{ safe_hook('templates.bottom') }}

    <div class="modal fade" id="template-create-modal" tabindex="-1" aria-labelledby="template-create-modal-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                {{ form_start(create_form, { action: path('admin.configuration.templates.create'), method: 'post', attr: { 'data-testid': 'template-create-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="template-create-modal-title">{{ 'Create a new template'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            {{ form_label(create_form.name) }}
                            {{ form_widget(create_form.name, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(create_form.name) }}
                        </div>
                        {{ form_widget(create_form.locale) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="template-create-submit">{{ 'Create'|trans }}</button>
                    </div>
                {{ form_end(create_form) }}
            </div>
        </div>
    </div>

    <div class="modal fade" id="template-duplicate-modal" tabindex="-1" aria-labelledby="template-duplicate-modal-title" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-template-id"
         data-bo-prefill-modal-target-input-value="source_template_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.configuration.templates.duplicate') }}?_token={{ assignToken() }}" method="post" data-testid="template-duplicate-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="template-duplicate-modal-title">{{ 'Duplicate template'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">{{ 'Choose a name for the new template (defaults to "Copy of <name>").'|trans }}</p>
                        <div class="mb-3">
                            <label for="template-duplicate-new-name" class="form-label">{{ 'New template name'|trans }}</label>
                            <input type="text" id="template-duplicate-new-name" name="new_name" class="form-control" placeholder="{{ 'Optional'|trans }}" data-testid="template-duplicate-new-name">
                        </div>
                        <input type="hidden" name="source_template_id" value="" data-bo-prefill-modal-target="input">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="template-duplicate-submit"><i class="bi bi-files"></i> {{ 'Duplicate'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="template-delete-modal" tabindex="-1" aria-labelledby="template-delete-modal-title" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-template-id"
         data-bo-prefill-modal-target-input-value="template_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.configuration.templates.delete') }}?_token={{ assignToken() }}" method="post" data-testid="template-delete-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="template-delete-modal-title">{{ 'Delete template'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this template?'|trans }}</p>
                        <input type="hidden" name="template_id" value="" data-bo-prefill-modal-target="input">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" data-testid="template-delete-submit">{{ 'Delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
