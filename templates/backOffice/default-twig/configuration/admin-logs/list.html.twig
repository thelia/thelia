{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Administration logs'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-admin-logs{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Administration logs'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('admin-logs.top') }}

    <div class="container-fluid" data-testid="admin-logs-page">
        <h1 class="h3 mb-3">{{ 'Administration logs'|trans }}</h1>

        <form action="{{ path('admin.configuration.admin-logs.logger') }}" method="post" data-testid="admin-logs-filter-form">
            <div class="card mb-3">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label for="admin-logs-from-date" class="form-label">{{ 'From'|trans }}</label>
                            <input type="date" id="admin-logs-from-date" name="fromDate" value="{{ from_date }}" class="form-control" data-testid="admin-logs-from-date">
                        </div>
                        <div class="col-md-3">
                            <label for="admin-logs-to-date" class="form-label">{{ 'To'|trans }}</label>
                            <input type="date" id="admin-logs-to-date" name="toDate" value="{{ to_date }}" class="form-control" data-testid="admin-logs-to-date">
                        </div>
                    </div>

                    <hr class="my-4">

                    <h2 class="h6">{{ 'Administrators'|trans }}</h2>
                    <div class="row g-2" data-testid="admin-logs-admins">
                        {% for admin in admins %}
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="admins[]" value="{{ admin.login }}" id="admin-logs-admin-{{ admin.id }}"
                                           {% if not submitted or admin.login in selected_admins %}checked{% endif %}>
                                    <label class="form-check-label" for="admin-logs-admin-{{ admin.id }}">
                                        {{ admin.login }} <span class="text-muted">({{ admin.firstname }} {{ admin.lastname }})</span>
                                    </label>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <hr class="my-4">

                    <h2 class="h6">{{ 'Resources'|trans }}</h2>
                    <div class="row g-2" data-testid="admin-logs-resources">
                        {% for resource in resources %}
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="resources[]" value="{{ resource.code }}" id="admin-logs-resource-{{ resource.id }}"
                                           {% if not submitted or resource.code in selected_resources %}checked{% endif %}>
                                    <label class="form-check-label" for="admin-logs-resource-{{ resource.id }}">
                                        {{ resource.code }}
                                    </label>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <hr class="my-4">

                    <h2 class="h6">{{ 'Modules'|trans }}</h2>
                    <div class="row g-2" data-testid="admin-logs-modules">
                        {% for module in modules %}
                            <div class="col-md-3">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="modules[]" value="{{ module.code }}" id="admin-logs-module-{{ module.id }}"
                                           {% if not submitted or module.code in selected_modules %}checked{% endif %}>
                                    <label class="form-check-label" for="admin-logs-module-{{ module.id }}">
                                        {{ module.code }}
                                    </label>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary" data-testid="admin-logs-show-button">
                        <i class="bi bi-eye" aria-hidden="true"></i>
                        {{ 'Show logs'|trans }}
                    </button>
                </div>
            </div>
        </form>

        {% if submitted %}
            <div class="card" data-testid="admin-logs-results">
                <div class="card-header bg-body-tertiary d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">{{ 'Log entries'|trans }}</h2>
                    <span class="badge bg-secondary" data-testid="admin-logs-count">{{ entries|length }}</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th scope="col">{{ 'Date'|trans }}</th>
                                <th scope="col">{{ 'Admin'|trans }}</th>
                                <th scope="col">{{ 'Resource'|trans }}</th>
                                <th scope="col">{{ 'Message'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in entries %}
                                <tr data-testid="admin-logs-row">
                                    <td><code>{{ entry.date }}</code></td>
                                    <td>{{ entry.admin }}</td>
                                    <td>
                                        <code>{{ entry.resource }}:{{ entry.action }}{% if entry.resource_id %}:{{ entry.resource_id }}{% endif %}</code>
                                    </td>
                                    <td>{{ entry.message }}</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4" data-testid="admin-logs-empty">
                                        {{ 'No log entries match the current filter.'|trans }}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% endif %}
    </div>

    {{ safe_hook('admin-logs.bottom') }}
{% endblock %}

{% block scripts_extra %}
    {{ safe_hook('admin-logs.js') }}
{% endblock %}
