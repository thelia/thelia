{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Customer titles'|trans }}{% endblock %}
{% block body_testid %}customer-titles-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Customer titles'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="customer-titles-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Customer titles'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.customer.title') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#customer-title-create-modal" data-testid="customer-title-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'Add a customer title'|trans }}
                </button>
            {% endif %}
        </div>

        {{ component('BoDataTable', {
            id: 'customer-titles',
            columns: [
                column('id', 'ID'|trans),
                column('short', 'Short'|trans),
                column('long', 'Long'|trans),
                column_toggle('default', 'Default'|trans, null),
                column('position', 'Position'|trans, 'center'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No customer title defined.'|trans,
        }) }}
    </div>

    {% if is_granted('CREATE', 'admin.customer.title') %}
        <div class="modal fade" id="customer-title-create-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    {{ form_start(create_form, { action: path('admin.configuration.customer-titles.create'), method: 'post' }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5">{{ 'New customer title'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        {{ form_row(create_form.short) }}
                        {{ form_row(create_form.long) }}
                        {{ form_row(create_form.default) }}
                    </div>
                    <div class="modal-footer">
                        {{ form_widget(create_form.locale) }}
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary">{{ 'Create'|trans }}</button>
                    </div>
                    {{ form_end(create_form, { render_rest: false }) }}
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
