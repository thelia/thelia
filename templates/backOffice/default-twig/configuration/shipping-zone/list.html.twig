{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Thelia Shipping zones'|trans }}{% endblock %}
{% block body_testid %}shipping-zones-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Shipping configuration'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('shipping-zones.top', { location: 'shipping_zones_top' }) }}

    <div class="container-fluid" data-testid="shipping-zones-page">
        <h1 class="h3 mb-3">{{ 'Shipping configuration'|trans }}</h1>

        {% if unattached_areas|length > 0 %}
            <div class="alert alert-warning" role="alert">
                <strong>{{ 'Warning'|trans }}</strong>, {{ 'some of your shipping zones are not attached to any delivery module:'|trans }}
                {% for area in unattached_areas %}
                    <a href="{{ path('admin.configuration.shipping-configuration.update.view', { area_id: area.id }) }}">{{ area.name }}</a>{% if not loop.last %}, {% else %}.{% endif %}
                {% endfor %}
            </div>
        {% endif %}

        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped align-middle mb-0">
                        <caption class="px-3 pt-3">{{ 'Shipping configuration'|trans }}</caption>
                        <thead>
                            <tr>
                                <th>{{ 'Delivery module'|trans }}</th>
                                <th>{{ 'Shipping zones for this module'|trans }}</th>
                                <th class="text-center">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% if rows|length == 0 %}
                                <tr>
                                    <td colspan="3">
                                        <div class="alert alert-info mb-0">{{ 'No shipping zone defined yet. Click the + button to create one.'|trans }}</div>
                                    </td>
                                </tr>
                            {% endif %}
                            {% for row in rows %}
                                <tr data-testid="shipping-zones-row-{{ row.id }}">
                                    <td><a href="{{ row.edit_url }}">{{ row.code }} - {{ row.title }}</a></td>
                                    <td>
                                        {% if row.zones|length == 0 %}
                                            <span class="text-muted">{{ 'There are no shipping zones attached to this module.'|trans }}</span>
                                        {% else %}
                                            {% for zone in row.zones %}
                                                <a href="{{ path('admin.configuration.shipping-configuration.update.view', { area_id: zone.id }) }}" title="{{ zone.countries }}">{{ zone.name }}</a>{% if not loop.last %}, {% endif %}
                                            {% endfor %}
                                        {% endif %}
                                    </td>
                                    <td class="text-center">
                                        {% if is_granted('UPDATE', 'admin.configuration.shipping-zone') %}
                                            <a class="btn btn-sm btn-outline-primary" href="{{ row.edit_url }}" title="{{ 'Change this shipping zone'|trans }}">
                                                <i class="bi bi-pencil" aria-hidden="true"></i>
                                            </a>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('shipping-zones.bottom', { location: 'shipping_zones_bottom' }) }}
{% endblock %}

{% block javascript_last_call %}
    {{ safe_hook('shipping-zones.js', { location: 'shipping-zones-js' }) }}
{% endblock %}
