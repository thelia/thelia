{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit tax rule'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-tax-rule-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.taxes-rules.list') }}">{{ 'Taxes rules'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ tax_rule.title ?: ('#' ~ tax_rule.id) }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {%- set active_tab = app.request.get('tab', 'data') -%}
    {{ safe_hook('tax-rule-edit.top', { tax_rule_id: tax_rule.id }) }}

    <div class="container-fluid" data-testid="tax-rule-edit-page">
        <h1 class="h3 mb-3">{{ 'Edit tax rule'|trans }}: <span class="text-muted" data-testid="tax-rule-edit-title">{{ tax_rule.title ?: ('#' ~ tax_rule.id) }}</span></h1>

        <ul class="nav nav-tabs mb-3" role="tablist" data-testid="tax-rule-edit-tabs">
            <li class="nav-item" role="presentation">
                <button class="nav-link {{ active_tab == 'data' ? 'active' : '' }}" id="tax-rule-tab-data" data-bs-toggle="tab" data-bs-target="#tax-rule-pane-data" type="button" role="tab">
                    <i class="bi bi-card-list" aria-hidden="true"></i> {{ 'Description'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {{ active_tab == 'taxes' ? 'active' : '' }}" id="tax-rule-tab-taxes" data-bs-toggle="tab" data-bs-target="#tax-rule-pane-taxes" type="button" role="tab">
                    <i class="bi bi-receipt" aria-hidden="true"></i> {{ 'Taxes'|trans }}
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade {{ active_tab == 'data' ? 'show active' : '' }}" id="tax-rule-pane-data" role="tabpanel">
                <div class="card">
                    <div class="card-body">
                        {{ form_start(form, {
                            action: path('admin.configuration.taxes-rules.save'),
                            method: 'post',
                            attr: { 'data-testid': 'tax-rule-edit-form' },
                        }) }}
                            <input type="hidden" name="tax_rule_id" value="{{ tax_rule.id }}">
                            {{ form_widget(form.id) }}
                            {{ form_widget(form.locale) }}
                            {{ form_row(form.title) }}
                            {{ form_row(form.description) }}
                            <div class="text-end">
                                <a href="{{ path('admin.configuration.taxes-rules.list') }}" class="btn btn-outline-secondary" data-testid="tax-rule-edit-cancel">
                                    {{ 'Cancel'|trans }}
                                </a>
                                <button type="submit" class="btn btn-primary" data-testid="tax-rule-edit-submit">
                                    <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                                </button>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>

            <div class="tab-pane fade {{ active_tab == 'taxes' ? 'show active' : '' }}" id="tax-rule-pane-taxes" role="tabpanel">
                {% include '@BackOfficeDefaultTwig/configuration/tax-rule/_matrix.html.twig' %}
            </div>
        </div>
    </div>

    {{ safe_hook('tax-rule-edit.bottom', { tax_rule_id: tax_rule.id }) }}
    {{ safe_hook('tax-rule.edit-js', { tax_rule_id: tax_rule.id, location: 'tax-rule-edit-js' }) }}
    {{ safe_hook('wysiwyg.js', { location: 'wysiwyg-tax-rule-edit-js' }) }}
{% endblock %}
