{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Taxes rules'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-taxes-rules{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Taxes rules'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('taxes-rules.top') }}

    <div class="container-fluid" data-testid="taxes-rules-page">
        <h1 class="h3 mb-3">{{ 'Taxes rules'|trans }}</h1>

        <div class="alert alert-info">
            <p class="mb-1">{{ 'Taxes define the amount of money added to the product price.'|trans }}</p>
            <p class="mb-0">{{ 'Tax rules are combinations of different taxes, applied per country.'|trans }}</p>
        </div>

        <section class="mb-4" data-testid="taxes-section">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h2 class="h5 mb-0">{{ 'Taxes'|trans }}</h2>
                {% if is_granted('CREATE', 'admin.configuration.tax') %}
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#tax-create-modal" data-testid="tax-create-button">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        {{ 'Create a new tax'|trans }}
                    </button>
                {% endif %}
            </div>

            {{ component('BoDataTable', {
                id: 'taxes',
                columns: [
                    column('title', 'Name'|trans),
                    column_html('description', 'Description'|trans),
                    column_actions('_actions', 'Actions'|trans),
                ],
                rows: tax_rows,
                emptyMessage: 'No tax defined yet.'|trans,
            }) }}
        </section>

        <section class="mb-4" data-testid="tax-rules-section">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h2 class="h5 mb-0">{{ 'Tax rules'|trans }}</h2>
                {% if is_granted('CREATE', 'admin.configuration.tax') %}
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#tax-rule-create-modal" data-testid="tax-rule-create-button">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        {{ 'Create a new tax rule'|trans }}
                    </button>
                {% endif %}
            </div>

            {{ component('BoDataTable', {
                id: 'tax-rules',
                columns: [
                    column('title', 'Name'|trans),
                    column_html('default_badge', 'Default'|trans),
                    column_actions('_actions', 'Actions'|trans),
                ],
                rows: tax_rule_rows|map(row => row|merge({
                    default_badge: row.is_default
                        ? '<span class="badge bg-success">' ~ ('Default'|trans) ~ '</span>'
                        : '',
                })),
                emptyMessage: 'No tax rule defined yet.'|trans,
            }) }}
        </section>

        {% if is_granted('UPDATE', 'admin.configuration.tax') %}
            <section data-testid="tax-rule-delivery-section">
                <h2 class="h5 mb-2">{{ 'Tax rule for delivery modules'|trans }}</h2>
                <div class="card">
                    <div class="card-body">
                        <form method="post" action="{{ path('admin.configuration.tax-rule.delivery.modules.update') }}" class="row g-3 align-items-end" data-testid="tax-rule-delivery-form">
                            <div class="col-md-9">
                                <label for="delivery-module-tax-rule" class="form-label">{{ 'Select a tax rule'|trans }}</label>
                                <select id="delivery-module-tax-rule" name="delivery-module-tax-rule" class="form-select">
                                    <option value="">{{ 'Select a tax rule'|trans }}</option>
                                    {% for option in delivery_tax_rules %}
                                        <option value="{{ option.id }}" {{ delivery_tax_rule_selected == option.id ? 'selected' : '' }}>{{ option.title }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3 text-end">
                                <button type="submit" class="btn btn-primary" data-testid="tax-rule-delivery-save">
                                    <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
        {% endif %}
    </div>

    {{ safe_hook('taxes-rules.bottom') }}
    {{ safe_hook('taxes-rules.js', { location: 'taxes-rules-js' }) }}

    {% include '@BackOfficeDefaultTwig/configuration/tax-rule/_tax_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/configuration/tax-rule/_tax_delete_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/configuration/tax-rule/_tax_rule_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/configuration/tax-rule/_tax_rule_delete_modal.html.twig' %}
{% endblock %}
