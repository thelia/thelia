{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Advanced configuration'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-advanced{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Advanced configuration'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('advanced-configuration.top') }}

    <div class="container-fluid" data-testid="advanced-config-page">
        <h1 class="h3 mb-4">{{ 'Advanced configuration'|trans }}</h1>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5"><i class="bi bi-archive" aria-hidden="true"></i> {{ 'Application cache'|trans }}</h2>
                        <p class="text-muted small">{{ 'Clear Symfony cache (templates, container, routing).'|trans }}</p>
                    </div>
                    <div class="card-footer text-end">
                        <a href="{{ path('admin.configuration.advanced.flush-cache') }}?_token={{ assignToken() }}" class="btn btn-warning" data-testid="advanced-flush-cache">
                            <i class="bi bi-trash3" aria-hidden="true"></i> {{ 'Flush cache'|trans }}
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5"><i class="bi bi-file-earmark-binary" aria-hidden="true"></i> {{ 'Compiled assets'|trans }}</h2>
                        <p class="text-muted small">{{ 'Clear public/assets compiled output (Webpack/Encore artifacts).'|trans }}</p>
                    </div>
                    <div class="card-footer text-end">
                        <a href="{{ path('admin.configuration.advanced.flush-assets') }}?_token={{ assignToken() }}" class="btn btn-warning" data-testid="advanced-flush-assets">
                            <i class="bi bi-trash3" aria-hidden="true"></i> {{ 'Flush assets'|trans }}
                        </a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h2 class="h5"><i class="bi bi-images" aria-hidden="true"></i> {{ 'Images and documents'|trans }}</h2>
                        <p class="text-muted small">{{ 'Clear generated images and documents cache directories.'|trans }}</p>
                    </div>
                    <div class="card-footer text-end">
                        <a href="{{ path('admin.configuration.advanced.flush-images-and-documents') }}?_token={{ assignToken() }}" class="btn btn-warning" data-testid="advanced-flush-images">
                            <i class="bi bi-trash3" aria-hidden="true"></i> {{ 'Flush images/documents'|trans }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('advanced-configuration.bottom') }}
{% endblock %}
