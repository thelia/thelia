{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'System variables'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-variables{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'System variables'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('variables.top') }}

    <div class="container-fluid" data-testid="variables-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'System variables'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.configuration.variable') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#variable-create-modal" data-testid="variable-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    {{ 'Add a new variable'|trans }}
                </button>
            {% endif %}
        </div>

        <form action="{{ path('admin.configuration.variables.update-values') }}" method="post" data-testid="variable-update-values-form">
            {{ component('BoDataTable', {
                id: 'variables',
                columns: [
                    column('title', 'Purpose'|trans),
                    column('name', 'Name'|trans),
                    column_html('value_html', 'Value'|trans),
                    column_actions('_actions', 'Actions'|trans),
                ],
                rows: rows,
                emptyMessage: 'No system variable defined yet.'|trans,
            }) }}

            {% if is_granted('UPDATE', 'admin.configuration.variable') %}
                <div class="mt-3 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary" data-testid="variable-update-values-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save values'|trans }}
                    </button>
                </div>
            {% endif %}
        </form>
    </div>

    {{ safe_hook('variables.bottom') }}

    {% include '@BackOfficeDefaultTwig/configuration/variable/_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/configuration/variable/_delete_modal.html.twig' %}

    {% for variable_id, edit_form in edit_forms %}
        {% include '@BackOfficeDefaultTwig/configuration/variable/_edit_modal.html.twig' with { variable_id: variable_id, form: edit_form } only %}
    {% endfor %}
{% endblock %}

{% block scripts_extra %}
    {{ safe_hook('variables.js') }}
{% endblock %}
