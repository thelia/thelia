<div class="modal fade" id="variable-create-modal" tabindex="-1" aria-labelledby="variable-create-modal-title" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            {{ form_start(create_form, { action: path('admin.configuration.variables.create'), method: 'post', attr: { 'data-testid': 'variable-create-form' } }) }}
                <div class="modal-header">
                    <h2 class="modal-title h5" id="variable-create-modal-title">{{ 'Create a new variable'|trans }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    {% include '@BackOfficeDefaultTwig/configuration/variable/_form_fields.html.twig' with { form: create_form } only %}
                    {{ safe_hook('variable.create-form') }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-primary" data-testid="variable-create-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Create this variable'|trans }}
                    </button>
                </div>
            {{ form_end(create_form) }}
        </div>
    </div>
</div>
