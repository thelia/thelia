{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Hooks'|trans }}{% endblock %}
{% block body_testid %}hooks-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Hooks'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('hooks.top', { location: 'hooks_top' }) }}

    <div class="container-fluid" data-testid="hooks-page"
         data-controller="bo-hooks"
         data-bo-hooks-list-url-value="{{ path('admin.hook') }}"
         data-bo-hooks-toggle-activation-url-value="{{ path('admin.hook.toggle-activation') }}"
         data-bo-hooks-toggle-native-url-value="{{ path('admin.hook.toggle-native') }}"
         data-bo-hooks-discover-url-value="{{ path('admin.hook.discover') }}"
         data-bo-hooks-discover-save-url-value="{{ path('admin.hook.discover.save') }}">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Hooks'|trans }}</h1>
            <div class="d-flex gap-2 align-items-center">
                <select class="form-select form-select-sm" data-bo-hooks-target="filter" data-action="change->bo-hooks#filter">
                    {% for value, label in type_options %}
                        <option value="{{ value }}"{% if value == current_type %} selected{% endif %}>{{ label }}</option>
                    {% endfor %}
                </select>
                {% if is_granted('CREATE', 'admin.hook') %}
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#hook-create-modal" data-testid="hook-create-btn">
                        <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>{{ 'Add a new hook'|trans }}
                    </button>
                {% endif %}
            </div>
        </div>

        {% if is_granted('UPDATE', 'admin.hook') %}
            <div class="card mb-3">
                <div class="card-body">
                    <h2 class="h5">{{ 'Check the support of hooks.'|trans }}</h2>
                    <div class="d-flex gap-2 align-items-center mt-3">
                        <select class="form-select" style="max-width:240px" data-bo-hooks-target="discoverType">
                            <option value="1">{{ 'Front Office'|trans }}</option>
                            <option value="2">{{ 'Back Office'|trans }}</option>
                            <option value="3">{{ 'pdf'|trans }}</option>
                            <option value="4">{{ 'email'|trans }}</option>
                        </select>
                        <button type="button" class="btn btn-outline-primary" data-action="bo-hooks#discover">{{ 'Parse template'|trans }}</button>
                    </div>
                    <div class="mt-3" data-bo-hooks-target="discoverContent"></div>
                </div>
            </div>
        {% endif %}

        {{ component('BoDataTable', {
            id: 'hooks',
            columns: [
                column('id', 'ID'|trans),
                column('code', 'Code'|trans),
                column('title', 'Title'|trans),
                column_badge('native_label', 'Official'|trans, { Yes: 'success', No: 'warning' }),
                column_badge('active_label', 'Active'|trans, { Yes: 'success', No: 'secondary' }),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No hooks has been created yet. Click the + button to create one.'|trans,
        }) }}

        <div class="d-flex justify-content-end gap-2 mt-3">
            <a href="/admin/modules" class="btn btn-outline-primary">{{ 'Manage modules'|trans }} <i class="bi bi-chevron-right" aria-hidden="true"></i></a>
            <a href="/admin/module-hooks" class="btn btn-outline-primary">{{ 'Manage modules attachements'|trans }} <i class="bi bi-chevron-right" aria-hidden="true"></i></a>
        </div>
    </div>

    {{ safe_hook('hooks.bottom', { location: 'hooks_bottom' }) }}

    {# Create modal #}
    <div class="modal fade" id="hook-create-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                {{ form_start(create_form, { attr: { action: path('admin.hook.create'), 'data-testid': 'hook-create-form' } }) }}
                    <div class="modal-header">
                        <h5 class="modal-title">{{ 'Create a new Hook'|trans }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        {{ form_row(create_form.code) }}
                        {{ form_row(create_form.type) }}
                        {{ form_row(create_form.title) }}
                        {{ form_row(create_form.active) }}
                        {{ safe_hook('hook.create-form', { location: 'hook_create_form' }) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary">{{ 'Create this hook'|trans }}</button>
                    </div>
                {{ form_end(create_form, { render_rest: false }) }}
            </div>
        </div>
    </div>

    {# Delete modal #}
    <div class="modal fade" id="hook-delete-modal" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-hook-id"
         data-bo-prefill-modal-target-input-value="hook_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="POST" action="{{ path('admin.hook.delete') }}?_token={{ assignToken() }}" data-testid="hook-delete-form">
                    <div class="modal-header">
                        <h5 class="modal-title">{{ 'Delete hook'|trans }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this hook ?'|trans }}</p>
                        <input type="hidden" name="hook_id" data-bo-prefill-modal-target="input">
                        {{ safe_hook('hook.delete-form', { location: 'hook_delete_form' }) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger">{{ 'Delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascript_last_call %}
    {{ safe_hook('hooks.js', { location: 'hooks-js' }) }}
{% endblock %}
