{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit tax'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-tax-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.taxes-rules.list') }}">{{ 'Taxes'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ tax.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('tax-edit.top', { tax_id: tax.id }) }}

    {% set tax_title = tax.title ?: ('Tax #' ~ tax.id) %}

    <div class="container-fluid" data-testid="tax-edit-page">
        <h1 class="h3 mb-3">{{ 'Edit tax'|trans }}: <span class="text-muted" data-testid="tax-edit-title">{{ tax_title }}</span></h1>

        {{ form_start(form, {
            action: path('admin.configuration.taxes.save'),
            method: 'post',
            attr: { 'data-testid': 'tax-edit-form' },
        }) }}
            <input type="hidden" name="tax_id" value="{{ tax.id }}">
            {{ form_widget(form.id) }}
            {{ form_widget(form.locale) }}

            <div class="card">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-12">{{ form_row(form.title) }}</div>
                        <div class="col-md-12">{{ form_row(form.description) }}</div>
                        <div class="col-md-6">{{ form_row(form.type) }}</div>
                    </div>

                    <div class="row g-3 mt-2" data-testid="tax-requirements">
                        {% for child in form %}
                            {% set field_name = child.vars.name %}
                            {% if field_name not in ['id', 'locale', 'title', 'description', 'type'] %}
                                {% set tax_type = child.vars.attr['data-tax-type'] ?? '' %}
                                <div class="col-md-6 tax-requirement" data-tax-type="{{ tax_type }}">
                                    {{ form_row(child) }}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        {{ 'Tax created on %date_create. Last modification: %date_change'|trans({
                            '%date_create': tax.createdAt ? tax.createdAt|format_datetime('medium', 'short') : '—',
                            '%date_change': tax.updatedAt ? tax.updatedAt|format_datetime('medium', 'short') : '—',
                        }) }}
                    </small>
                    <div class="d-flex gap-2">
                        <a href="{{ path('admin.configuration.taxes-rules.list') }}" class="btn btn-outline-secondary" data-testid="tax-edit-cancel">
                            {{ 'Cancel'|trans }}
                        </a>
                        <button type="submit" class="btn btn-primary" data-testid="tax-edit-submit">
                            <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                        </button>
                    </div>
                </div>
            </div>
        {{ form_end(form) }}
    </div>

    {{ safe_hook('tax-edit.bottom', { tax_id: tax.id }) }}

    <script>
        (function () {
            const form = document.querySelector('[data-testid="tax-edit-form"]');
            if (!form) return;
            const select = form.querySelector('#thelia_tax_modification_type');
            if (!select) return;
            const groups = form.querySelectorAll('.tax-requirement');

            function sync() {
                const current = select.value;
                groups.forEach(function (group) {
                    const matches = group.dataset.taxType === current;
                    group.style.display = matches ? '' : 'none';
                    group.querySelectorAll('input, select, textarea').forEach(function (input) {
                        input.disabled = !matches;
                    });
                });
            }

            select.addEventListener('change', sync);
            sync();
        })();
    </script>
{% endblock %}
