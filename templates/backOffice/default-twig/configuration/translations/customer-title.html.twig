{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Translations-customers-titles'|trans }}{% endblock %}
{% block body_testid %}translations-customer-title{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Translations-customers-titles'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="translations-customer-title-page">
        <h1 class="h3 mb-3">{{ 'Translations-customers-titles'|trans }}</h1>

        <form method="POST" id="translation_form" action="{{ path('admin.configuration.translations-customers-title.update') }}" data-testid="translations-customer-title-form">
            <input type="hidden" name="locale" value="{{ edit_language_locale }}">
            <input type="hidden" name="edit_language_id" value="{{ edit_language_id }}">

            <div class="card">
                <div class="card-body p-0">
                    <table class="table table-striped align-middle mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'Short'|trans }}</th>
                                <th>{{ 'Long'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for title in titles %}
                                <tr data-testid="translations-customer-title-row-{{ title.id }}">
                                    <td>
                                        <input type="text" class="form-control" id="short_title_{{ title.id }}" name="short_title_{{ title.id }}" value="{{ title.short }}" required>
                                    </td>
                                    <td>
                                        <input type="text" class="form-control" id="long_title_{{ title.id }}" name="long_title_{{ title.id }}" value="{{ title.long }}" required>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <button type="submit" class="btn btn-outline-secondary" name="save_mode" value="close">{{ 'Save and close'|trans }}</button>
                <button type="submit" class="btn btn-primary">{{ 'Save'|trans }}</button>
            </div>
        </form>
    </div>
{% endblock %}
