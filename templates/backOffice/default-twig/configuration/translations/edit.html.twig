{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Translations'|trans }}{% endblock %}
{% block body_testid %}translations-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Translations'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="translations-page"
         data-controller="bo-translations"
         data-bo-translations-base-url-value="{{ path('admin.configuration.translations') }}">

        <h1 class="h3 mb-3">{{ 'Translations'|trans }}</h1>

        {% if is_writable is same as false %}
            <div class="alert alert-danger">{{ 'The directory local/I18n does not exist or is not writable. Please fix this issue before.'|trans }}</div>
        {% endif %}

        <form method="POST" id="translation_form" action="{{ path('admin.configuration.translations.update') }}" data-testid="translations-form">
            <input type="hidden" name="edit_language_id" value="{{ edit_language_id }}">

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <label class="form-label" for="item_to_translate">{{ 'Items to translate'|trans }}</label>
                    <select id="item_to_translate" name="item_to_translate" class="form-select" data-action="change->bo-translations#changeItem">
                        <option value="">{{ 'Please select items to translate'|trans }}</option>
                        <option value="fo"{% if item_to_translate == 'fo' %} selected{% endif %}>{{ 'Front-office templates'|trans }}</option>
                        <option value="pf"{% if item_to_translate == 'pf' %} selected{% endif %}>{{ 'PDF templates'|trans }}</option>
                        <option value="ma"{% if item_to_translate == 'ma' %} selected{% endif %}>{{ 'E-mail templates'|trans }}</option>
                        <option value="bo"{% if item_to_translate == 'bo' %} selected{% endif %}>{{ 'Back-office templates'|trans }}</option>
                        <option value="mo"{% if item_to_translate == 'mo' %} selected{% endif %}>{{ 'Modules'|trans }}</option>
                        <option value="co"{% if item_to_translate == 'co' %} selected{% endif %}>{{ 'Thelia core'|trans }}</option>
                        <option value="in"{% if item_to_translate == 'in' %} selected{% endif %}>{{ 'Thelia Installation'|trans }}</option>
                        <option value="wi"{% if item_to_translate == 'wi' %} selected{% endif %}>{{ 'Thelia Installation Wizard'|trans }}</option>
                    </select>
                </div>

                {% if item_to_translate == 'mo' %}
                    <div class="col-md-4">
                        <label class="form-label" for="item_name">{{ 'Module you want to translate'|trans }}</label>
                        <select id="item_name" name="item_name" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the module to translate'|trans }}</option>
                            {% for module in modules %}
                                <option value="{{ module.id }}"{% if item_name == module.id ~ '' %} selected{% endif %}>{{ module.code }} - {{ module.title }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% elseif item_to_translate == 'fo' %}
                    <div class="col-md-4">
                        <label class="form-label" for="item_name">{{ 'Front-office template you want to translate'|trans }}</label>
                        <select id="item_name" name="item_name" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the F.O. template to translate'|trans }}</option>
                            {% for name in fo_templates %}
                                <option value="{{ name }}"{% if item_name == name %} selected{% endif %}>{{ name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% elseif item_to_translate == 'bo' %}
                    <div class="col-md-4">
                        <label class="form-label" for="item_name">{{ 'Back-office template you want to translate'|trans }}</label>
                        <select id="item_name" name="item_name" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the B.O. template to translate'|trans }}</option>
                            {% for name in bo_templates %}
                                <option value="{{ name }}"{% if item_name == name %} selected{% endif %}>{{ name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% elseif item_to_translate == 'ma' %}
                    <div class="col-md-4">
                        <label class="form-label" for="item_name">{{ 'E-mail template you want to translate'|trans }}</label>
                        <select id="item_name" name="item_name" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the E-mail template to translate'|trans }}</option>
                            {% for name in email_templates %}
                                <option value="{{ name }}"{% if item_name == name %} selected{% endif %}>{{ name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% elseif item_to_translate == 'pf' %}
                    <div class="col-md-4">
                        <label class="form-label" for="item_name">{{ 'PDF template you want to translate'|trans }}</label>
                        <select id="item_name" name="item_name" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the PDF template to translate'|trans }}</option>
                            {% for name in pdf_templates %}
                                <option value="{{ name }}"{% if item_name == name %} selected{% endif %}>{{ name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                {% endif %}

                {% if item_to_translate == 'mo' and item_name != '' %}
                    <div class="col-md-4">
                        <label class="form-label" for="module_part">{{ 'Module component'|trans }}</label>
                        <select id="module_part" name="module_part" class="form-select" data-action="change->bo-translations#submitForm">
                            <option value="">{{ 'Please select the module component'|trans }}</option>
                            <option value="core"{% if module_part == 'core' %} selected{% endif %}>{{ 'Core files'|trans }}</option>
                            {% if has_admin_includes %}
                                <option value="admin-includes"{% if module_part == 'admin-includes' %} selected{% endif %}>{{ 'Administration includes template'|trans }}</option>
                            {% endif %}
                            {% if back_office_templates != '' %}
                                {% for name in back_office_templates|split(',') %}
                                    <option value="bo.{{ name }}"{% if module_part == 'bo.' ~ name %} selected{% endif %}>{{ 'Back-office template'|trans }} "{{ name }}"</option>
                                {% endfor %}
                            {% endif %}
                            {% if front_office_templates != '' %}
                                {% for name in front_office_templates|split(',') %}
                                    <option value="fo.{{ name }}"{% if module_part == 'fo.' ~ name %} selected{% endif %}>{{ 'Front-office template'|trans }} "{{ name }}"</option>
                                {% endfor %}
                            {% endif %}
                            {% if email_templates_for_module != '' %}
                                {% for name in email_templates_for_module|split(',') %}
                                    <option value="email.{{ name }}"{% if module_part == 'email.' ~ name %} selected{% endif %}>{{ 'Email template'|trans }} "{{ name }}"</option>
                                {% endfor %}
                            {% endif %}
                            {% if pdf_templates_for_module != '' %}
                                {% for name in pdf_templates_for_module|split(',') %}
                                    <option value="pdf.{{ name }}"{% if module_part == 'pdf.' ~ name %} selected{% endif %}>{{ 'Pdf template'|trans }} "{{ name }}"</option>
                                {% endfor %}
                            {% endif %}
                        </select>
                    </div>
                {% endif %}
            </div>

            <div class="alert alert-info">
                <p>
                    <i class="bi bi-info-circle me-1" aria-hidden="true"></i>
                    {{ 'This page allows you to translate each <strong>resources</strong> of your website : Thelia, modules, templates.'|trans|raw }}
                </p>
                <ul>
                    <li>{{ 'Redefine the text only for this resource.'|trans }}</li>
                    <li>{{ 'Redefine the text globally. Every text will be translated with this translation, except if there is a translation for this resource.'|trans }}</li>
                </ul>
            </div>

            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="view_missing_traductions_only" name="view_missing_traductions_only" value="1"{% if view_missing_only %} checked{% endif %} data-action="change->bo-translations#submitForm">
                <label class="form-check-label" for="view_missing_traductions_only">{{ 'View only missing translations.'|trans }}</label>
            </div>

            {% if max_input_vars_warning %}
                <div class="alert alert-danger">
                    {{ 'Cannot translate all fields. According to your PHP configuration, forms cannot contains more than %current_max_input_vars input fields, but at least %required_max_input_vars are required.'|trans({
                        '%current_max_input_vars': current_max_input_vars,
                        '%required_max_input_vars': required_max_input_vars,
                    }) }}
                </div>
            {% elseif all_strings is empty and item_to_translate != '' %}
                <div class="alert alert-info">{{ 'Did not found any text to translate.'|trans }}</div>
            {% else %}
                {% set current_file = false %}
                {% set idx = 0 %}
                {% for info in all_strings %}
                    {% set not_translated = info.translation is empty and info.custom_fallback is empty and info.global_fallback is empty %}
                    {% if view_missing_only is same as false or not_translated %}
                        {% set file_names = info.files|length > 1 ? info.files|join(', ') : info.files[0] %}
                        {% if file_names != current_file %}
                            {% if not loop.first %}
                                        </tbody>
                                    </table>
                                </div>
                            {% endif %}
                            {% set current_file = file_names %}
                            <div class="card mb-3">
                                <div class="card-header">{{ 'In page'|trans }} {{ file_names }}</div>
                                <div class="card-body p-0">
                                    <table class="table table-striped mb-0">
                                        <tbody>
                        {% endif %}

                        <tr>
                            <td class="col-md-6">
                                <input type="hidden" name="text[]" value="{{ info.text }}">
                                {{ info.text }}
                            </td>
                            <td class="col-md-6">
                                <div class="input-group input-group-sm mb-1">
                                    <span class="input-group-text">›</span>
                                    <input type="text" name="translation[]" value="{{ info.translation }}" class="form-control" data-testid="translation-input">
                                </div>
                                <div class="input-group input-group-sm mb-1">
                                    <span class="input-group-text" title="{{ 'Custom redefinition'|trans }}">★</span>
                                    <input type="text" name="translation_custom[]" value="{{ info.custom_fallback }}" class="form-control" placeholder="{{ 'specific redefinition'|trans }}">
                                </div>
                                <div class="input-group input-group-sm">
                                    <span class="input-group-text" title="{{ 'Global redefinition'|trans }}">»</span>
                                    <input type="text" name="translation_global[]" value="{{ info.global_fallback }}" class="form-control" placeholder="{{ 'global redefinition'|trans }}">
                                </div>
                            </td>
                        </tr>

                        {% set idx = idx + 1 %}
                    {% else %}
                        <input type="hidden" name="translation[]" value="{{ info.translation }}">
                        <input type="hidden" name="translation_custom[]" value="{{ info.custom_fallback }}">
                        <input type="hidden" name="translation_global[]" value="{{ info.global_fallback }}">
                    {% endif %}
                {% endfor %}
                {% if current_file is not same as false %}
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                {% endif %}
            {% endif %}

            {% if item_to_translate != '' and is_writable %}
                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="submit" class="btn btn-outline-secondary" name="save_mode" value="close">{{ 'Save and close'|trans }}</button>
                    <button type="submit" class="btn btn-primary" name="save_mode" value="stay">{{ 'Save and stay'|trans }}</button>
                </div>
            {% endif %}
        </form>
    </div>
{% endblock %}
