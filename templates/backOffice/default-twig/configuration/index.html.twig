{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Configuration'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-index{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Configuration'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% set sections = [
    {
        title: 'Store'|trans,
        items: [
            { route: 'admin.configuration.store.default', label: 'Store info'|trans, icon: 'bi-shop' },
        ],
    },
    {
        title: 'System'|trans,
        items: [
            { route: 'admin.configuration.languages.default', label: 'Languages'|trans, icon: 'bi-translate' },
            { route: 'admin.configuration.currencies.default', label: 'Currencies'|trans, icon: 'bi-currency-exchange' },
            { route: 'admin.configuration.variables.default', label: 'System variables'|trans, icon: 'bi-sliders' },
            { route: 'admin.configuration.admin-logs.view', label: 'Administration logs'|trans, icon: 'bi-clipboard-data' },
            { route: 'admin.configuration.profiles.list', label: 'Profiles'|trans, icon: 'bi-shield-lock' },
            { route: 'admin.configuration.administrators.view', label: 'Administrators'|trans, icon: 'bi-people' },
            { route: 'admin.configuration.advanced', label: 'Advanced configuration'|trans, icon: 'bi-tools' },
        ],
    },
    {
        title: 'Shipping'|trans,
        items: [
            { route: 'admin.configuration.shipping-zones.default', label: 'Shipping configuration'|trans, icon: 'bi-truck' },
            { route: 'admin.configuration.shipping-configuration.default', label: 'Shipping zones management'|trans, icon: 'bi-map' },
        ],
    },
] %}

{% block content %}
    {{ safe_hook('configuration.top') }}

    <div class="container-fluid" data-testid="configuration-page">
        <h1 class="h3 mb-4">{{ 'Configuration'|trans }}</h1>

        {% for section in sections %}
            <h2 class="h5 text-muted mb-3">{{ section.title }}</h2>
            <div class="row g-3 mb-4" data-testid="configuration-section">
                {% for item in section.items %}
                    <div class="col-md-3">
                        <a href="{{ path(item.route) }}" class="card text-decoration-none h-100" data-testid="configuration-link-{{ item.route }}">
                            <div class="card-body d-flex align-items-center gap-3">
                                <i class="bi {{ item.icon }} fs-3 text-primary" aria-hidden="true"></i>
                                <span class="fw-medium text-body">{{ item.label }}</span>
                            </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% endfor %}
    </div>

    {{ safe_hook('configuration.bottom') }}
{% endblock %}
