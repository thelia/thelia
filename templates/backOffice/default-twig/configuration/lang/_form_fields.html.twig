{% if form.id is defined %}
    {{ form_widget(form.id) }}
{% endif %}
<div class="row g-3">
    <div class="col-md-6">{{ form_row(form.title) }}</div>
    <div class="col-md-6">{{ form_row(form.code) }}</div>
    <div class="col-md-6">{{ form_row(form.locale) }}</div>
    <div class="col-md-6">{{ form_row(form.date_time_format) }}</div>
    <div class="col-md-6">{{ form_row(form.date_format) }}</div>
    <div class="col-md-6">{{ form_row(form.time_format) }}</div>
    <div class="col-md-4">{{ form_row(form.decimal_separator) }}</div>
    <div class="col-md-4">{{ form_row(form.thousands_separator) }}</div>
    <div class="col-md-4">{{ form_row(form.decimals) }}</div>
</div>
