<div class="modal fade" id="lang-delete-modal" tabindex="-1" aria-labelledby="lang-delete-modal-title" aria-hidden="true"
     data-controller="bo-prefill-modal"
     data-bo-prefill-modal-source-trigger-value="data-lang-id"
     data-bo-prefill-modal-target-input-value="language_id">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="{{ path('admin.configuration.languages.delete') }}?_token={{ assignToken() }}"
                  method="post"
                  data-testid="lang-delete-form">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="lang-delete-modal-title">{{ 'Delete language'|trans }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Do you really want to delete this language?'|trans }}</p>
                    <input type="hidden" name="language_id" value="" data-bo-prefill-modal-target="input">
                    {{ safe_hook('languages.delete-form') }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-danger" data-testid="lang-delete-submit">
                        <i class="bi bi-trash" aria-hidden="true"></i> {{ 'Delete'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
