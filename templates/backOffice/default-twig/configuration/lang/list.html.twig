{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Languages'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-languages{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Languages'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('languages.top') }}

    <div class="container-fluid" data-testid="languages-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Languages management'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.configuration.language') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#lang-create-modal" data-testid="lang-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    {{ 'Add a new language'|trans }}
                </button>
            {% endif %}
        </div>

        {{ component('BoDataTable', {
            id: 'languages',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'Language name'|trans),
                column('code', 'ISO 639 Code'|trans),
                column('locale', 'Locale'|trans),
                column_toggle('visible', 'Visible in front'|trans, 'toggle_visible_url'),
                column_toggle('active', 'Active'|trans, 'toggle_active_url'),
                column_toggle('default', 'Default'|trans, 'toggle_default_url'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No language defined yet.'|trans,
        }) }}

        <div class="row g-4 mt-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-body-tertiary">
                        <h2 class="h5 mb-0">{{ 'Parameters'|trans }}</h2>
                    </div>
                    <div class="card-body">
                        {{ form_start(default_behavior_form, { action: path('admin.configuration.languages.defaultBehavior'), method: 'post', attr: { 'data-testid': 'lang-default-behavior-form' } }) }}
                            {{ form_row(default_behavior_form.behavior) }}
                            <div class="text-end">
                                <button type="submit" class="btn btn-primary" data-testid="lang-default-behavior-submit">
                                    <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                                </button>
                            </div>
                        {{ form_end(default_behavior_form) }}
                    </div>
                </div>
            </div>

            <div class="col-md-6">
                <div class="card">
                    <div class="card-header bg-body-tertiary">
                        <h2 class="h5 mb-0">{{ 'Using a domain or subdomain for each language'|trans }}</h2>
                    </div>
                    <div class="card-body">
                        {{ form_start(url_form, { action: path('admin.configuration.languages.updateUrl'), method: 'post', attr: { 'data-testid': 'lang-url-form' } }) }}
                            <table class="table table-sm align-middle">
                                <tbody>
                                    {% for field in url_form %}
                                        <tr>
                                            <th scope="row">{{ field.vars.label }}</th>
                                            <td>
                                                <input type="text"
                                                       class="form-control"
                                                       name="{{ field.vars.full_name }}"
                                                       value="{{ field.vars.value }}"
                                                       placeholder="http://www.example.com"
                                                       {% if not one_domain_per_lang %}readonly{% endif %}>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                            <div class="d-flex justify-content-end gap-2 mt-2">
                                {% if one_domain_per_lang %}
                                    <a href="{{ path('admin.configuration.languages.domain.deactivation') }}" class="btn btn-outline-danger" data-testid="lang-domain-deactivate">
                                        <i class="bi bi-x-circle" aria-hidden="true"></i> {{ 'Deactivate'|trans }}
                                    </a>
                                {% else %}
                                    <a href="{{ path('admin.configuration.languages.domain.activation') }}" class="btn btn-outline-success" data-testid="lang-domain-activate">
                                        <i class="bi bi-check-circle" aria-hidden="true"></i> {{ 'Activate'|trans }}
                                    </a>
                                {% endif %}
                                <button type="submit" class="btn btn-primary" {% if not one_domain_per_lang %}disabled{% endif %} data-testid="lang-url-submit">
                                    <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                                </button>
                            </div>
                        {{ form_end(url_form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('languages.bottom') }}

    {% include '@BackOfficeDefaultTwig/configuration/lang/_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/configuration/lang/_delete_modal.html.twig' %}

    {% for lang_id, edit_form in edit_forms %}
        {% include '@BackOfficeDefaultTwig/configuration/lang/_edit_modal.html.twig' with { lang_id: lang_id, form: edit_form } only %}
    {% endfor %}
{% endblock %}

{% block scripts_extra %}
    {{ safe_hook('languages.js') }}
{% endblock %}
