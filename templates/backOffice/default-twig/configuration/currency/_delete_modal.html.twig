<div class="modal fade" id="currency-delete-modal" tabindex="-1" aria-labelledby="currency-delete-modal-title" aria-hidden="true"
     data-controller="bo-prefill-modal"
     data-bo-prefill-modal-source-trigger-value="data-currency-id"
     data-bo-prefill-modal-target-input-value="currency_id">
    <div class="modal-dialog">
        <div class="modal-content">
            <form action="{{ path('admin.configuration.currencies.delete') }}?_token={{ assignToken() }}"
                  method="post"
                  data-testid="currency-delete-form">
                <div class="modal-header">
                    <h2 class="modal-title h5" id="currency-delete-modal-title">{{ 'Delete currency'|trans }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Do you really want to delete this currency?'|trans }}</p>
                    <input type="hidden" name="currency_id" value="" data-bo-prefill-modal-target="input">
                    {{ safe_hook('currency.delete-form') }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-danger" data-testid="currency-delete-submit">
                        <i class="bi bi-trash" aria-hidden="true"></i> {{ 'Delete'|trans }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
