{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Messages'|trans }}{% endblock %}
{% block body_testid %}messages-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Messages'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="messages-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Mail messages'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.configuration.message') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#message-create-modal" data-testid="message-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'Add a message'|trans }}
                </button>
            {% endif %}
        </div>

        {{ component('BoDataTable', {
            id: 'messages',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'Purpose'|trans),
                column('name', 'Name'|trans),
                column_badge('secured_label', 'Type'|trans, { System: 'warning', User: 'info' }),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No mailing template has been created yet. Click the + button to create one.'|trans,
        }) }}
    </div>

    {% if is_granted('CREATE', 'admin.configuration.message') %}
        <div class="modal fade" id="message-create-modal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    {{ form_start(create_form, { action: path('admin.configuration.messages.create'), method: 'post' }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5">{{ 'New message'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        {{ form_row(create_form.message_name) }}
                        {{ form_row(create_form.title) }}
                        {{ form_row(create_form.secured) }}
                    </div>
                    <div class="modal-footer">
                        {{ form_widget(create_form.locale) }}
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary">{{ 'Create'|trans }}</button>
                    </div>
                    {{ form_end(create_form, { render_rest: false }) }}
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
