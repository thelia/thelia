{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit mailing template'|trans }} — {{ message.name }}{% endblock %}
{% block body_testid %}message-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.messages.default') }}">{{ 'Mailing templates'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Editing mailing template "%name"'|trans({'%name': message.name}) }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('message-edit.top', { message_id: message.id }) }}

    <div class="container-fluid"
         data-testid="message-edit-page"
         data-controller="bo-message-preview"
         data-bo-message-preview-html-url-value="{{ preview_html_url }}"
         data-bo-message-preview-text-url-value="{{ preview_text_url }}"
         data-bo-message-preview-send-url-value="{{ send_test_url }}"
    >
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Edit mailing template "%name"'|trans({'%name': message.name}) }}</h1>
            <a href="{{ path('admin.configuration.messages.default') }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> {{ 'Back'|trans }}
            </a>
        </div>

        <ul class="nav nav-tabs mb-3" id="message-edit-tabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="tab-data" data-bs-toggle="tab" data-bs-target="#data" type="button" role="tab" aria-controls="data" aria-selected="true">
                    {{ 'Message data'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="tab-preview" data-bs-toggle="tab" data-bs-target="#preview" type="button" role="tab" aria-controls="preview" aria-selected="false">
                    {{ 'Preview'|trans }}
                </button>
            </li>
        </ul>

        <div class="tab-content" id="message-edit-tabs-content">
            <div class="tab-pane fade show active" id="data" role="tabpanel" aria-labelledby="tab-data">
                <div class="card">
                    <div class="card-body">
                        {{ form_start(form, { action: path('admin.configuration.messages.save'), method: 'post', attr: { 'data-testid': 'message-edit-form' } }) }}
                            <input type="hidden" name="message_id" value="{{ message.id }}">
                            <div class="row g-3">
                                <div class="col-md-4">{{ form_row(form.message_name) }}</div>
                                <div class="col-md-8">{{ form_row(form.title) }}</div>
                                <div class="col-12">{{ form_row(form.subject) }}</div>
                                <div class="col-12">
                                    <label class="form-label small text-uppercase text-muted">{{ 'HTML version of this message'|trans }}</label>
                                    {{ form_widget(form.html_message, { attr: { rows: 12, 'data-testid': 'message-html', class: 'form-control text-monospace' } }) }}
                                </div>
                                <div class="col-12">
                                    <label class="form-label small text-uppercase text-muted">{{ 'Text version of this message'|trans }}</label>
                                    {{ form_widget(form.text_message, { attr: { rows: 10, 'data-testid': 'message-text', class: 'form-control text-monospace' } }) }}
                                </div>
                                <div class="col-12">
                                    <div class="form-check">
                                        {{ form_widget(form.secured, { attr: { class: 'form-check-input' } }) }}
                                        {{ form_label(form.secured, null, { label_attr: { class: 'form-check-label' } }) }}
                                    </div>
                                </div>
                            </div>
                            {{ form_widget(form.id) }}
                            {{ form_widget(form.locale) }}
                            {{ safe_hook('message.update-form', { message_id: message.id }) }}
                            <div class="d-flex justify-content-end gap-2 mt-3">
                                <a href="{{ path('admin.configuration.messages.default') }}" class="btn btn-outline-secondary">{{ 'Cancel'|trans }}</a>
                                <button type="submit" class="btn btn-primary" data-testid="message-save">
                                    <i class="bi bi-check2"></i> {{ 'Save'|trans }}
                                </button>
                            </div>
                        {{ form_end(form, { render_rest: false }) }}
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="preview" role="tabpanel" aria-labelledby="tab-preview">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
                            <button type="button" class="btn btn-primary" data-action="bo-message-preview#previewHtml" data-testid="message-preview-html">
                                <i class="bi bi-eye"></i> {{ 'Preview HTML'|trans }}
                            </button>
                            <button type="button" class="btn btn-outline-primary" data-action="bo-message-preview#previewText" data-testid="message-preview-text">
                                <i class="bi bi-file-text"></i> {{ 'Preview text'|trans }}
                            </button>
                            <div class="ms-auto d-flex gap-2 align-items-center">
                                <input type="email" class="form-control form-control-sm" placeholder="{{ 'Recipient email'|trans }}" value="{{ store_email }}" data-bo-message-preview-target="recipient" required>
                                <button type="button" class="btn btn-success btn-sm" data-action="bo-message-preview#sendSample" data-testid="message-send-test">
                                    <i class="bi bi-envelope-arrow-up"></i> {{ 'Send'|trans }}
                                </button>
                            </div>
                        </div>
                        <div class="mb-3 small text-muted" data-bo-message-preview-target="result"></div>

                        <div class="table-responsive">
                            <table class="table table-striped table-sm" data-bo-message-preview-target="variablesTable">
                                <caption class="caption-top">{{ 'Variables to inject'|trans }}</caption>
                                <thead>
                                    <tr>
                                        <th>{{ 'Name'|trans }}</th>
                                        <th>{{ 'Value'|trans }}</th>
                                        <th class="text-end" style="width: 4rem;">&nbsp;</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr class="url-variable">
                                        <td><input type="text" class="form-control form-control-sm" data-bo-message-preview-target="varKey"></td>
                                        <td><input type="text" class="form-control form-control-sm" data-bo-message-preview-target="varValue"></td>
                                        <td class="text-end"></td>
                                    </tr>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3">
                                            <button type="button" class="btn btn-sm btn-outline-secondary" data-action="bo-message-preview#addVariable">
                                                <i class="bi bi-plus-circle"></i> {{ 'Add a variable'|trans }}
                                            </button>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="message-preview-modal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title h5">{{ 'Preview'|trans }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body p-0" data-bo-message-preview-target="modalBody">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Close'|trans }}</button>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('message-edit.bottom', { message_id: message.id }) }}
{% endblock %}
