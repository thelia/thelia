{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit attribute'|trans }} — {{ attribute.title }}{% endblock %}
{% block body_testid %}configuration-attribute-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.attributes.default') }}">{{ 'Attributes'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ attribute.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('attribute.top', { attribute: attribute.id }) }}

    <div class="container-fluid" data-testid="attribute-edit-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Attribute'|trans }} <small class="text-muted">#{{ attribute.id }}</small></h1>
            <div class="d-flex gap-2">
                <a href="{{ path('admin.configuration.attributes.add-to-all', { attribute_id: attribute.id }) }}?_token={{ assignToken() }}" class="btn btn-outline-secondary" data-testid="attribute-add-to-all">
                    <i class="bi bi-plus-square" aria-hidden="true"></i> {{ 'Add to all templates'|trans }}
                </a>
                <a href="{{ path('admin.configuration.attributes.rem-from-all', { attribute_id: attribute.id }) }}?_token={{ assignToken() }}" class="btn btn-outline-secondary" data-testid="attribute-rem-from-all">
                    <i class="bi bi-x-square" aria-hidden="true"></i> {{ 'Remove from all templates'|trans }}
                </a>
                <a href="{{ path('admin.configuration.attributes.default') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'Back to list'|trans }}
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-md-7">
                <div class="card">
                    <div class="card-header">{{ 'General'|trans }}</div>
                    <div class="card-body">
                        {{ form_start(form, { action: path('admin.configuration.attributes.save', { attribute_id: attribute.id }), method: 'post', attr: { 'data-testid': 'attribute-edit-form' } }) }}
                            <input type="hidden" name="attribute_id" value="{{ attribute.id }}">
                            <div class="mb-3">
                                {{ form_label(form.title) }}
                                {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                                {{ form_errors(form.title) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.chapo) }}
                                {{ form_widget(form.chapo, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.description) }}
                                {{ form_widget(form.description, { attr: { class: 'form-control', rows: 6 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.postscriptum) }}
                                {{ form_widget(form.postscriptum, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                            {{ form_widget(form.id) }}
                            {{ form_widget(form.locale) }}
                            {{ safe_hook('attribute.update-form', { attribute: attribute.id }) }}
                            <button type="submit" class="btn btn-primary" data-testid="attribute-edit-submit">
                                <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                            </button>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span>{{ 'Values'|trans }}</span>
                        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#attribute-av-create-modal" data-testid="attributeav-create-button">
                            <i class="bi bi-plus" aria-hidden="true"></i> {{ 'Add'|trans }}
                        </button>
                    </div>
                    <table class="table mb-0" data-testid="attributeav-table">
                        <thead>
                            <tr>
                                <th>{{ 'Title'|trans }}</th>
                                <th class="text-center">{{ 'Position'|trans }}</th>
                                <th class="text-end">{{ 'Actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody data-controller="bo-sortable"
                               data-bo-sortable-url-value="{{ av_position_url }}"
                               data-bo-sortable-token-value="{{ av_position_token }}"
                               data-bo-sortable-param-name-value="attributeav_id">
                            {% for av in attribute_avs %}
                                <tr data-id="{{ av.id }}" data-testid="attributeav-row-{{ av.id }}">
                                    <td>{{ av.title }}</td>
                                    <td class="text-center">{{ av.position }}</td>
                                    <td class="text-end">
                                        <a href="{{ av.delete_url }}" class="btn btn-sm btn-outline-danger" data-testid="attributeav-delete-{{ av.id }}" onclick="return confirm('{{ 'Delete this value?'|trans }}')">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </a>
                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="3" class="text-muted text-center">{{ 'No value yet.'|trans }}</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('attribute.bottom', { attribute: attribute.id }) }}

    <div class="modal fade" id="attribute-av-create-modal" tabindex="-1" aria-labelledby="attribute-av-create-modal-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                {{ form_start(av_create_form, { action: path('admin.configuration.attributes-av.create'), method: 'post', attr: { 'data-testid': 'attributeav-create-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="attribute-av-create-modal-title">{{ 'Add a attribute value'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            {{ form_label(av_create_form.title) }}
                            {{ form_widget(av_create_form.title, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(av_create_form.title) }}
                        </div>
                        {{ form_widget(av_create_form.locale) }}
                        {{ form_widget(av_create_form.attribute_id) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="attributeav-create-submit">{{ 'Add'|trans }}</button>
                    </div>
                {{ form_end(av_create_form) }}
            </div>
        </div>
    </div>
{% endblock %}
