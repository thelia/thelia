{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit country'|trans }} — {{ country.title }}{% endblock %}
{% block body_testid %}country-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.countries.default') }}">{{ 'Countries'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ country.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="country-edit-page">
        <h1 class="h3 mb-3">{{ 'Country'|trans }} <small class="text-muted">{{ country.isoalpha2 }} — #{{ country.id }}</small></h1>

        <div class="card">
            <div class="card-body">
                {{ form_start(form, { action: path('admin.configuration.countries.save'), method: 'post' }) }}
                    <input type="hidden" name="country_id" value="{{ country.id }}">
                    <div class="row g-3">
                        <div class="col-md-6">{{ form_row(form.title) }}</div>
                        <div class="col-md-2">{{ form_row(form.isocode) }}</div>
                        <div class="col-md-2">{{ form_row(form.isoalpha2) }}</div>
                        <div class="col-md-2">{{ form_row(form.isoalpha3) }}</div>
                        <div class="col-md-4">{{ form_row(form.area) }}</div>
                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                {{ form_widget(form.visible, { attr: { class: 'form-check-input' } }) }}
                                {{ form_label(form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mt-4">
                                {{ form_widget(form.has_states, { attr: { class: 'form-check-input' } }) }}
                                {{ form_label(form.has_states, null, { label_attr: { class: 'form-check-label' } }) }}
                            </div>
                        </div>
                    </div>
                    {{ form_widget(form.id) }}
                    {{ form_widget(form.locale) }}
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a href="{{ path('admin.configuration.countries.default') }}" class="btn btn-outline-secondary">{{ 'Cancel'|trans }}</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check2"></i> {{ 'Save'|trans }}</button>
                    </div>
                {{ form_end(form, { render_rest: false }) }}
            </div>
        </div>
    </div>
{% endblock %}
