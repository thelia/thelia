{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Countries'|trans }}{% endblock %}
{% block body_testid %}countries-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Countries'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="countries-page">
        <h1 class="h3 mb-3">{{ 'Countries'|trans }}</h1>

        {{ component('BoDataTable', {
            id: 'countries',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'Country'|trans),
                column('isoalpha2', 'ISO-2'|trans, 'center'),
                column('isoalpha3', 'ISO-3'|trans, 'center'),
                column('isocode', 'Numeric'|trans, 'center'),
                column_toggle('visible', 'Online'|trans, null),
                column_toggle('default', 'Default'|trans, null),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No country defined.'|trans,
        }) }}
    </div>
{% endblock %}
