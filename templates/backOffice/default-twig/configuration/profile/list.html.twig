{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Profiles'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}configuration-profiles{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.index') }}">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Profiles'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('profiles.top') }}

    <div class="container-fluid" data-testid="profiles-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Profiles management'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.configuration.profile') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#profile-create-modal" data-testid="profile-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    {{ 'Add a new profile'|trans }}
                </button>
            {% endif %}
        </div>

        {{ component('BoDataTable', {
            id: 'profiles',
            columns: [
                column('id', 'ID'|trans),
                column('code', 'Code'|trans),
                column('title', 'Title'|trans),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No profile defined yet.'|trans,
        }) }}
    </div>

    {{ safe_hook('profiles.bottom') }}

    <div class="modal fade" id="profile-create-modal" tabindex="-1" aria-labelledby="profile-create-modal-title" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                {{ form_start(create_form, { action: path('admin.configuration.profiles.add'), method: 'post', attr: { 'data-testid': 'profile-create-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="profile-create-modal-title">{{ 'Create a new profile'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        {{ form_widget(create_form.locale) }}
                        <div class="row g-3">
                            <div class="col-md-6">{{ form_row(create_form.code) }}</div>
                            <div class="col-md-6">{{ form_row(create_form.title) }}</div>
                            <div class="col-md-12">{{ form_row(create_form.chapo) }}</div>
                            <div class="col-md-12">{{ form_row(create_form.description) }}</div>
                            <div class="col-md-12">{{ form_row(create_form.postscriptum) }}</div>
                        </div>
                        {{ safe_hook('profile.create-form') }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="profile-create-submit">
                            <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Create this profile'|trans }}
                        </button>
                    </div>
                {{ form_end(create_form) }}
            </div>
        </div>
    </div>

    <div class="modal fade" id="profile-delete-modal" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-profile-id"
         data-bo-prefill-modal-target-input-value="profile_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.configuration.profiles.delete') }}?_token={{ assignToken() }}" method="post" data-testid="profile-delete-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5">{{ 'Delete profile'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this profile?'|trans }}</p>
                        <input type="hidden" name="profile_id" value="" data-bo-prefill-modal-target="input">
                        {{ safe_hook('profile.delete-form') }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" data-testid="profile-delete-submit">
                            <i class="bi bi-trash" aria-hidden="true"></i> {{ 'Delete'|trans }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
