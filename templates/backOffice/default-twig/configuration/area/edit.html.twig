{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit a shipping configuration'|trans }}{% endblock %}
{% block body_testid %}shipping-configuration-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.configuration.shipping-configuration.default') }}">{{ 'Shipping zones management'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Editing shipping zone "%name"'|trans({ '%name': area.name }) }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('shipping-configuration-edit.top', { area_id: area_id }) }}

    <div class="container-fluid" data-testid="shipping-configuration-edit-page"
         data-controller="bo-area-edit"
         data-bo-area-edit-area-id-value="{{ area_id }}"
         data-bo-area-edit-data-url-value="{{ countries_data_url }}"
         data-bo-area-edit-initial-value="{{ countries_in_area|json_encode|e('html_attr') }}"
         data-bo-area-edit-unassigned-value="{{ unassigned_country_ids|json_encode|e('html_attr') }}"
         data-bo-area-edit-states-all-label-value="{{ 'All States'|trans }}">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Shipping zone "%title"'|trans({ '%title': area.name }) }}</h1>
            <a href="{{ path('admin.configuration.shipping-configuration.default') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-x-lg me-1" aria-hidden="true"></i>{{ 'Close'|trans }}
            </a>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="card mb-3">
                    <div class="card-body">
                        {{ form_start(form, { attr: { action: path('admin.configuration.shipping-configuration.save', { area_id: area_id }), 'data-testid': 'shipping-configuration-save-form' } }) }}
                            <div class="input-group">
                                {{ form_widget(form.name, { attr: { 'aria-label': 'Shipping zone name'|trans } }) }}
                                <button type="submit" class="btn btn-primary">{{ 'Update'|trans }}</button>
                            </div>
                            {{ form_errors(form.name) }}
                        {{ form_end(form, { render_rest: true }) }}
                    </div>
                </div>

                <div class="card">
                    <div class="card-body">
                        <form method="POST" action="{{ path('admin.configuration.shipping-configuration.country.add') }}" data-testid="shipping-configuration-add-country-form">
                            <input type="hidden" name="area_id" value="{{ area_id }}">

                            <div class="mb-2">
                                <input type="text" class="form-control form-control-sm" placeholder="{{ 'filter country'|trans }}" data-bo-area-edit-target="filter">
                            </div>

                            <select multiple class="form-select" size="12" name="country_id[]" data-bo-area-edit-target="addSelect" data-testid="shipping-configuration-countries-to-add"></select>

                            <button type="submit" class="btn btn-primary w-100 mt-2">
                                <i class="bi bi-plus-lg me-1" aria-hidden="true"></i>{{ 'Add selected countries'|trans }}
                            </button>
                            <button type="button" class="btn btn-outline-info w-100 mt-1" data-action="bo-area-edit#selectUnassigned">
                                <i class="bi bi-gear me-1" aria-hidden="true"></i>{{ 'Select unassigned countries'|trans }}
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <div class="card">
                    <div class="card-body">
                        <form method="POST" action="{{ path('admin.configuration.shipping-configuration.countries.remove') }}" data-testid="shipping-configuration-remove-countries-form">
                            <input type="hidden" name="area_id" value="{{ area_id }}">

                            <div class="table-responsive">
                                <table class="table table-striped table-sm align-middle">
                                    <thead>
                                        <tr>
                                            <th>{{ 'Countries assigned to this zone'|trans }}</th>
                                            <th class="text-end">
                                                <a href="#" data-action="bo-area-edit#selectAll">{{ 'all'|trans }}</a>
                                                — <a href="#" data-action="bo-area-edit#selectNone">{{ 'none'|trans }}</a>
                                                — <a href="#" data-action="bo-area-edit#selectReverse">{{ 'reverse'|trans }}</a>
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody data-bo-area-edit-target="addedBody" data-testid="shipping-configuration-countries-added"></tbody>
                                </table>
                            </div>

                            {{ safe_hook('shipping-configuration.edit', { area_id: area_id, location: 'shipping-configuration-edit' }) }}

                            <button type="submit" class="btn btn-primary float-end">
                                <i class="bi bi-trash me-1" aria-hidden="true"></i>{{ 'Delete selected countries'|trans }}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{ safe_hook('shipping-configuration-edit.bottom', { area_id: area_id }) }}
{% endblock %}

{% block javascript_last_call %}
    {{ safe_hook('shipping-configuration.edit-js', { area_id: area_id, location: 'shipping-configuration-edit-js' }) }}
{% endblock %}
