{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'States'|trans }}{% endblock %}
{% block body_testid %}states-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="/admin/configuration">{{ 'Configuration'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'States'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="states-page">
        <h1 class="h3 mb-3">{{ 'States'|trans }}</h1>

        <form method="get" action="{{ path('admin.configuration.states.default') }}" class="row g-2 mb-3">
            <div class="col-md-6">
                <label class="form-label" for="state-country-filter">{{ 'Filter by country'|trans }}</label>
                <select name="country_id" id="state-country-filter" class="form-select">
                    <option value="0">{{ 'All countries'|trans }}</option>
                    {% for country in countries %}
                        <option value="{{ country.id }}" {% if country.id == current_country %}selected{% endif %}>{{ country.title }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-secondary" type="submit">{{ 'Filter'|trans }}</button>
            </div>
        </form>

        {{ component('BoDataTable', {
            id: 'states',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'State'|trans),
                column('isocode', 'ISO'|trans, 'center'),
                column('country', 'Country'|trans),
                column_toggle('visible', 'Online'|trans, null),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No state defined.'|trans,
        }) }}
    </div>
{% endblock %}
