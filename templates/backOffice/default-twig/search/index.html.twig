{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Search results for'|trans }} {{ term }}{% endblock %}
{% block body_testid %}search-results{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Search'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="search-page">
        <h1 class="h3 mb-3">{{ 'Search results'|trans }} <small class="text-muted">"{{ term }}"</small></h1>

        {% if term is empty %}
            <p class="text-muted">{{ 'Type a search term in the top bar.'|trans }}</p>
        {% else %}
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">{{ 'Products'|trans }} <span class="badge bg-secondary ms-1">{{ products|length }}</span></div>
                        <ul class="list-group list-group-flush">
                            {% for product in products %}
                                <li class="list-group-item d-flex justify-content-between"><a class="text-decoration-none" href="{{ path('admin.products.update', { product_id: product.id }) }}">{{ product.title }}</a><span class="text-muted small">{{ product.ref }}</span></li>
                            {% else %}
                                <li class="list-group-item text-muted small">{{ 'No product match.'|trans }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">{{ 'Categories'|trans }} <span class="badge bg-secondary ms-1">{{ categories|length }}</span></div>
                        <ul class="list-group list-group-flush">
                            {% for category in categories %}
                                <li class="list-group-item"><a class="text-decoration-none" href="{{ path('admin.categories.update', { category_id: category.id }) }}">{{ category.title }}</a></li>
                            {% else %}
                                <li class="list-group-item text-muted small">{{ 'No category match.'|trans }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">{{ 'Customers'|trans }} <span class="badge bg-secondary ms-1">{{ customers|length }}</span></div>
                        <ul class="list-group list-group-flush">
                            {% for customer in customers %}
                                <li class="list-group-item"><a class="text-decoration-none" href="{{ path('admin.customer.update.view', { customer_id: customer.id }) }}">{{ customer.firstname }} {{ customer.lastname }}</a> <span class="text-muted small">{{ customer.email }}</span></li>
                            {% else %}
                                <li class="list-group-item text-muted small">{{ 'No customer match.'|trans }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">{{ 'Orders'|trans }} <span class="badge bg-secondary ms-1">{{ orders|length }}</span></div>
                        <ul class="list-group list-group-flush">
                            {% for order in orders %}
                                <li class="list-group-item"><a class="text-decoration-none" href="{{ path('admin.order.update.view', { order_id: order.id }) }}">{{ order.ref }}</a></li>
                            {% else %}
                                <li class="list-group-item text-muted small">{{ 'No order match.'|trans }}</li>
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
