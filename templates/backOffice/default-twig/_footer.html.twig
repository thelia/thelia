{# Back-office footer — mirrors the Smarty admin-layout.tpl footer markup
   and hook names. #}

{{ safe_hook('main.before-footer', { location: 'before_footer' }) }}

<footer class="bo-footer mt-4 py-3 px-4 border-top text-muted small d-flex flex-wrap justify-content-between align-items-center" data-testid="bo-footer">
    <div>
        <strong>&copy; Thelia <time datetime="{{ 'now'|date('Y') }}">{{ 'now'|date('Y') }}</time></strong>
        — <a href="https://thelia.net/" target="_blank" rel="noopener" class="link-secondary">thelia.net</a>
        — <a href="https://github.com/thelia/thelia" target="_blank" rel="noopener" class="link-secondary">{{ 'Need help?'|trans }}</a>
        {{ safe_hook('main.in-footer', { location: 'in_footer' }) }}
    </div>
    <ul class="list-inline mb-0">
        <li class="list-inline-item">
            <a href="https://twitter.com/theliaecommerce" target="_blank" rel="noopener" class="link-secondary" aria-label="Twitter"><i class="bi bi-twitter-x" aria-hidden="true"></i></a>
        </li>
        <li class="list-inline-item">
            <a href="https://www.facebook.com/theliaecommerce" target="_blank" rel="noopener" class="link-secondary" aria-label="Facebook"><i class="bi bi-facebook" aria-hidden="true"></i></a>
        </li>
        <li class="list-inline-item">
            <a href="https://github.com/thelia/thelia" target="_blank" rel="noopener" class="link-secondary" aria-label="GitHub"><i class="bi bi-github" aria-hidden="true"></i></a>
        </li>
    </ul>
</footer>

{{ safe_hook('main.after-footer', { location: 'after_footer' }) }}
