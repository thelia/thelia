<div data-testid="product-related-tab">
    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"
                     data-controller="bo-folder-content-picker"
                     data-bo-folder-content-picker-url-template-value="{{ available_related_content_url }}">
                    <h2 class="h5 mb-1">{{ 'Related content'|trans }}</h2>
                    <p class="text-muted">{{ 'You can attach here some content to this product'|trans }}</p>

                    {% if folder_tree|length > 0 %}
                        <form method="post" action="{{ path('admin.products.related-content.add') }}" class="mb-3" data-testid="product-related-content-form">
                            <input type="hidden" name="product_id" value="{{ product.id }}">
                            <input type="hidden" name="current_tab" value="related">
                            <input type="hidden" name="_token" value="{{ token }}">
                            <div class="mb-2">
                                <label for="product-folder-id" class="form-label">{{ 'Folder'|trans }}</label>
                                <select id="product-folder-id" name="folder_id" class="form-select"
                                        data-bo-folder-content-picker-target="folder"
                                        data-action="change->bo-folder-content-picker#folderChanged">
                                    <option value="">{{ 'Select a folder...'|trans }}</option>
                                    {% for folder in folder_tree %}
                                        <option value="{{ folder.id }}" style="padding-left: {{ 3 + folder.level * 20 }}px">{{ folder.title }}</option>
                                    {% endfor %}
                                </select>
                                <small class="form-text text-muted">{{ 'Select a folder to get its content'|trans }}</small>
                            </div>
                            <div data-bo-folder-content-picker-target="picker" class="d-none">
                                <label for="product-content-id" class="form-label">{{ 'Content'|trans }}</label>
                                <div class="input-group">
                                    <select id="product-content-id" name="content_id" class="form-select" required
                                            data-bo-folder-content-picker-target="content">
                                        <option value="">{{ 'Select a folder content...'|trans }}</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary" data-testid="product-related-content-add">
                                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <small class="form-text text-muted">{{ 'Select a content and click + to add it to this product'|trans }}</small>
                            </div>
                            <div data-bo-folder-content-picker-target="empty" class="d-none alert alert-info mt-2 mb-0">{{ 'No available content in this folder'|trans }}</div>
                        </form>
                    {% else %}
                        <div class="alert alert-info">{{ 'No folders found'|trans }}</div>
                    {% endif %}

                    <div class="table-responsive">
                        <table class="table align-middle"
                               data-testid="product-related-content-table"
                               data-controller="bo-sortable"
                               data-bo-sortable-url-value="{{ update_content_position_url }}?product_id={{ product.id }}&current_tab=related&mode=1"
                               data-bo-sortable-token-value="{{ token }}"
                               data-bo-sortable-param-name-value="content_id">
                            <thead>
                                <tr>
                                    <th style="width: 60px;">{{ 'ID'|trans }}</th>
                                    <th>{{ 'Content title'|trans }}</th>
                                    <th class="text-center" style="width: 80px;">{{ 'Position'|trans }}</th>
                                    {{ safe_hook('product.contents-table-header', { product_id: product.id }) }}
                                    <th class="text-end" style="width: 80px;">{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for content in assigned_contents %}
                                    <tr data-row-id="{{ content.id }}" data-testid="product-related-content-row-{{ content.id }}">
                                        <td>{{ content.id }}</td>
                                        <td><a href="{{ content.url }}">{{ content.title }}</a></td>
                                        <td class="text-center">{{ content.position }}</td>
                                        {{ safe_hook('product.contents-table-row', { product_id: product.id, content_id: content.id }) }}
                                        <td class="text-end">
                                            {% if is_granted('UPDATE', 'admin.product') %}
                                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#product-related-content-delete" data-content-id="{{ content.id }}" data-testid="product-related-content-delete-{{ content.id }}">
                                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                                </button>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="4" class="text-muted text-center">{{ 'This product contains no contents'|trans }}</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body"
                     data-controller="bo-category-product-picker"
                     data-bo-category-product-picker-url-template-value="{{ available_accessories_url }}">
                    <h2 class="h5 mb-1">{{ 'Product accessories'|trans }}</h2>
                    <p class="text-muted">{{ 'Define here this product accessories'|trans }}</p>

                    {% if category_tree_for_accessory|length > 0 %}
                        <form method="post" action="{{ path('admin.products.accessories.add') }}" class="mb-3" data-testid="product-accessory-form">
                            <input type="hidden" name="product_id" value="{{ product.id }}">
                            <input type="hidden" name="current_tab" value="related">
                            <input type="hidden" name="_token" value="{{ token }}">
                            <div class="mb-2">
                                <label for="product-accessory-category-id" class="form-label">{{ 'Category'|trans }}</label>
                                <select id="product-accessory-category-id" name="accessory_category_id" class="form-select"
                                        data-bo-category-product-picker-target="category"
                                        data-action="change->bo-category-product-picker#categoryChanged">
                                    <option value="">{{ 'Select a category...'|trans }}</option>
                                    {% for category in category_tree_for_accessory %}
                                        <option value="{{ category.id }}" style="padding-left: {{ 3 + category.level * 20 }}px">{{ category.title }}</option>
                                    {% endfor %}
                                </select>
                                <small class="form-text text-muted">{{ 'Select a category to get its products'|trans }}</small>
                            </div>
                            <div data-bo-category-product-picker-target="picker" class="d-none">
                                <label for="product-accessory-id" class="form-label">{{ 'Product'|trans }}</label>
                                <div class="input-group">
                                    <select id="product-accessory-id" name="accessory_id" class="form-select" required
                                            data-bo-category-product-picker-target="product">
                                        <option value="">{{ 'Select a product...'|trans }}</option>
                                    </select>
                                    <button type="submit" class="btn btn-primary" data-testid="product-accessory-add">
                                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <small class="form-text text-muted">{{ 'Select a product and click + to add it as an accessory'|trans }}</small>
                            </div>
                            <div data-bo-category-product-picker-target="empty" class="d-none alert alert-info mt-2 mb-0">{{ 'No available product in this category'|trans }}</div>
                        </form>
                    {% else %}
                        <div class="alert alert-info">{{ 'No categories found'|trans }}</div>
                    {% endif %}

                    <div class="table-responsive">
                        <table class="table align-middle"
                               data-testid="product-accessory-table"
                               data-controller="bo-sortable"
                               data-bo-sortable-url-value="{{ update_accessory_position_url }}?product_id={{ product.id }}&current_tab=related&mode=1"
                               data-bo-sortable-token-value="{{ token }}"
                               data-bo-sortable-param-name-value="accessory_id">
                            <thead>
                                <tr>
                                    <th style="width: 60px;">{{ 'ID'|trans }}</th>
                                    <th>{{ 'Accessory title'|trans }}</th>
                                    <th class="text-center" style="width: 80px;">{{ 'Position'|trans }}</th>
                                    {{ safe_hook('product.accessories-table-header', { product_id: product.id }) }}
                                    <th class="text-end" style="width: 80px;">{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for accessory in assigned_accessories %}
                                    <tr data-row-id="{{ accessory.accessory_id }}" data-testid="product-accessory-row-{{ accessory.accessory_id }}">
                                        <td>{{ accessory.accessory_id }}</td>
                                        <td>{{ accessory.title }}</td>
                                        <td class="text-center">{{ accessory.position }}</td>
                                        {{ safe_hook('product.accessories-table-row', { product_id: product.id, accessory_id: accessory.accessory_id }) }}
                                        <td class="text-end">
                                            {% if is_granted('UPDATE', 'admin.product') %}
                                                <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#product-accessory-delete" data-accessory-id="{{ accessory.accessory_id }}" data-testid="product-accessory-delete-{{ accessory.accessory_id }}">
                                                    <i class="bi bi-trash" aria-hidden="true"></i>
                                                </button>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr><td colspan="4" class="text-muted text-center">{{ 'This product contains no accessories'|trans }}</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-3">
        <div class="card-body">
            <h2 class="h5 mb-1">{{ 'Additional categories'|trans }}</h2>
            <p class="text-muted">{{ 'A product can be attached to more than one category. Select here the additional categories for this product.'|trans }}</p>

            {% if category_tree_for_additional|length > 0 %}
                <form method="post" action="{{ path('admin.products.additional-category.add') }}" class="mb-3" data-testid="product-additional-category-form">
                    <input type="hidden" name="product_id" value="{{ product.id }}">
                    <input type="hidden" name="current_tab" value="related">
                    <input type="hidden" name="_token" value="{{ token }}">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-9">
                            <label for="product-additional-category-id" class="form-label">{{ 'Category'|trans }}</label>
                            <select id="product-additional-category-id" name="category_id" class="form-select" required>
                                <option value="">{{ 'Select a category...'|trans }}</option>
                                {% for category in category_tree_for_additional %}
                                    <option value="{{ category.id }}" {% if category.disabled %}disabled{% endif %} style="padding-left: {{ 3 + category.level * 20 }}px">{{ category.title }}{% if category.id == default_category_id %} {{ '(default)'|trans }}{% endif %}</option>
                                {% endfor %}
                            </select>
                            <small class="form-text text-muted">{{ 'Select a category and click + to add it to the additional category list'|trans }}</small>
                        </div>
                        <div class="col-md-3">
                            <button type="submit" class="btn btn-primary w-100" data-testid="product-additional-category-add">
                                <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'Add'|trans }}
                            </button>
                        </div>
                    </div>
                </form>
            {% else %}
                <div class="alert alert-info">{{ 'No categories found'|trans }}</div>
            {% endif %}

            <div class="table-responsive">
                <table class="table align-middle" data-testid="product-additional-category-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;">{{ 'ID'|trans }}</th>
                            <th>{{ 'Category title'|trans }}</th>
                            {{ safe_hook('product.categories-table-header', { product_id: product.id }) }}
                            <th class="text-end" style="width: 80px;">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for additional in additional_categories %}
                            <tr data-testid="product-additional-category-row-{{ additional.id }}">
                                <td>{{ additional.id }}</td>
                                <td>{{ additional.title }}</td>
                                {{ safe_hook('product.categories-table-row', { product_id: product.id, category_id: additional.id }) }}
                                <td class="text-end">
                                    {% if is_granted('UPDATE', 'admin.product') %}
                                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#product-additional-category-delete" data-category-id="{{ additional.id }}" data-testid="product-additional-category-delete-{{ additional.id }}">
                                            <i class="bi bi-trash" aria-hidden="true"></i>
                                        </button>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3" class="text-muted text-center">{{ 'This product does not belong to any additional category.'|trans }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {{ safe_hook('product-edit.related-tab', { product: product.id }) }}

    <div class="modal fade" id="product-related-content-delete" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-content-id"
         data-bo-prefill-modal-target-input-value="content_id">
        <div class="modal-dialog">
            <form method="post" action="{{ path('admin.products.related-content.delete') }}?_token={{ token }}" class="modal-content" data-testid="product-related-content-delete-form">
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'Remove related content'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Do you really want to remove this related content from the product?'|trans }}</p>
                    <input type="hidden" name="product_id" value="{{ product.id }}">
                    <input type="hidden" name="content_id" value="" data-bo-prefill-modal-target="input">
                    <input type="hidden" name="current_tab" value="related">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-danger">{{ 'Confirm'|trans }}</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="product-accessory-delete" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-accessory-id"
         data-bo-prefill-modal-target-input-value="accessory_id">
        <div class="modal-dialog">
            <form method="post" action="{{ path('admin.products.accessories.delete') }}?_token={{ token }}" class="modal-content" data-testid="product-accessory-delete-form">
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'Remove an accessory'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Do you really want to remove this accessory from the product?'|trans }}</p>
                    <input type="hidden" name="product_id" value="{{ product.id }}">
                    <input type="hidden" name="accessory_id" value="" data-bo-prefill-modal-target="input">
                    <input type="hidden" name="current_tab" value="related">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-danger">{{ 'Confirm'|trans }}</button>
                </div>
            </form>
        </div>
    </div>

    <div class="modal fade" id="product-additional-category-delete" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-category-id"
         data-bo-prefill-modal-target-input-value="category_id">
        <div class="modal-dialog">
            <form method="post" action="{{ path('admin.products.additional-category.delete') }}?_token={{ token }}" class="modal-content" data-testid="product-additional-category-delete-form">
                <div class="modal-header">
                    <h5 class="modal-title">{{ 'Remove from category'|trans }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <p>{{ 'Do you really want to remove the product from this category?'|trans }}</p>
                    <input type="hidden" name="product_id" value="{{ product.id }}">
                    <input type="hidden" name="category_id" value="" data-bo-prefill-modal-target="input">
                    <input type="hidden" name="current_tab" value="related">
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-danger">{{ 'Confirm'|trans }}</button>
                </div>
            </form>
        </div>
    </div>
</div>
