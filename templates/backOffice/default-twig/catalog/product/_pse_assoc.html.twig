<div class="modal fade" id="pse-assoc-modal" tabindex="-1" aria-labelledby="pse-assoc-modal-label" aria-hidden="true"
     data-controller="bo-pse-assoc-picker"
     data-bo-pse-assoc-picker-list-url-template-value="{{ path('admin.product_sale_elements.document_image_assoc.get_assoc', { type: 'TYPE', id: 0 }) }}"
     data-bo-pse-assoc-picker-toggle-url-template-value="{{ path('admin.product_sale_elements.document_image_assoc', { pseId: 0, type: 'TYPE', typeId: 0 }) }}">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="pse-assoc-modal-label" data-bo-pse-assoc-picker-target="title">{{ 'Associate files'|trans }}</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small" data-bo-pse-assoc-picker-target="hint" data-image-hint="{{ 'Click an image to associate or dissociate it.'|trans }}" data-document-hint="{{ 'Click a document to associate or dissociate it.'|trans }}" data-virtual-hint="{{ 'Only non-visible documents are listed.'|trans }}"></p>
                <div data-bo-pse-assoc-picker-target="loading" class="text-center py-4 text-muted" hidden>
                    <div class="spinner-border" role="status" aria-hidden="true"></div>
                    <p class="mt-2">{{ 'Loading…'|trans }}</p>
                </div>
                <div data-bo-pse-assoc-picker-target="empty" class="text-center py-4 text-muted" hidden>
                    {{ 'No file available.'|trans }}
                </div>
                <div data-bo-pse-assoc-picker-target="grid" class="row g-3"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Close'|trans }}</button>
            </div>
        </div>
    </div>
</div>
