{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Products'|trans }}{% endblock %}
{% block body_testid %}catalog-products{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Products'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('products.top') }}

    <div class="container-fluid" data-testid="products-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Products management'|trans }}</h1>
            {% if is_granted('CREATE', 'admin.product') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#product-create-modal" data-testid="product-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'Add a new product'|trans }}
                </button>
            {% endif %}
        </div>

        <form method="get" action="{{ path('admin.products.default') }}" class="row g-2 mb-3" data-testid="product-search-form">
            <div class="col-md-4">
                <label class="form-label">{{ 'Category'|trans }}</label>
                <select name="category_id" class="form-select" data-testid="product-filter-category">
                    {% for cat in available_categories %}
                        <option value="{{ cat.id }}" {% if cat.id == current_category %}selected{% endif %}>{{ cat.title }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">{{ 'Search (title/ref)'|trans }}</label>
                <input type="search" name="q" value="{{ current_search }}" class="form-control" data-testid="product-search-input">
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-secondary" data-testid="product-search-submit">{{ 'Search'|trans }}</button>
                <a href="{{ path('admin.products.default') }}" class="btn btn-outline-secondary" data-testid="product-search-clear">{{ 'Reset'|trans }}</a>
            </div>
        </form>

        {{ component('BoDataTable', {
            id: 'products',
            columns: [
                column('id', 'ID'|trans),
                column('ref', 'Reference'|trans),
                column('title', 'Title'|trans),
                column_toggle('visible', 'Online'|trans, 'toggle_visible_url'),
                column('position', 'Position'|trans, 'center'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No product matches the current filters.'|trans,
            tbodyAttributes: {
                'data-controller': 'bo-sortable',
                'data-bo-sortable-url-value': update_position_url,
                'data-bo-sortable-token-value': update_position_token,
                'data-bo-sortable-param-name-value': 'product_id',
            },
        }) }}

        {% if pages > 1 %}
            <nav aria-label="{{ 'Product pagination'|trans }}" data-testid="product-pagination">
                <ul class="pagination">
                    {% for p in 1..pages %}
                        <li class="page-item {% if p == current_page %}active{% endif %}">
                            <a class="page-link" href="?{% if current_category > 0 %}category_id={{ current_category }}&{% endif %}{% if current_search %}q={{ current_search }}&{% endif %}page={{ p }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        {% endif %}
    </div>

    {{ safe_hook('products.bottom') }}

    <div class="modal fade" id="product-create-modal" tabindex="-1" aria-labelledby="product-create-modal-title" aria-hidden="true"
         data-controller="bo-price-preview"
         data-bo-price-preview-url-value="{{ path('admin.product.calculate-price') }}"
         data-bo-price-preview-prefix-value="≈ "
         data-bo-price-preview-suffix-value=" {{ 'incl. tax'|trans }}">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                {{ form_start(create_form, { action: path('admin.products.create'), method: 'post', attr: { 'data-testid': 'product-create-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="product-create-modal-title">{{ 'Create a new product'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(create_form.ref) }}
                                {{ form_widget(create_form.ref, { attr: { class: 'form-control' } }) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(create_form.title) }}
                                {{ form_widget(create_form.title, { attr: { class: 'form-control' } }) }}
                            </div>
                            <div class="col-md-6 mb-3">
                                {{ form_label(create_form.default_category) }}
                                <select name="{{ create_form.default_category.vars.full_name }}" class="form-select" required>
                                    {% for cat in available_categories %}
                                        {% if cat.id > 0 %}
                                            <option value="{{ cat.id }}">{{ cat.title }}</option>
                                        {% endif %}
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3 mb-3 pt-4">
                                {{ form_row(create_form.visible) }}
                            </div>
                            <div class="col-md-3 mb-3 pt-4">
                                {{ form_row(create_form.virtual) }}
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(create_form.price) }}
                                {{ form_widget(create_form.price, { attr: { class: 'form-control', step: 0.01, 'data-bo-price-preview-target': 'price' } }) }}
                                <small class="form-text text-muted" data-bo-price-preview-target="output" data-testid="product-create-price-preview"></small>
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(create_form.currency) }}
                                <select name="{{ create_form.currency.vars.full_name }}" class="form-select">
                                    {% for c in available_currencies %}
                                        <option value="{{ c.id }}" {% if c.default %}selected{% endif %}>{{ c.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                {{ form_label(create_form.tax_rule) }}
                                <select name="{{ create_form.tax_rule.vars.full_name }}" class="form-select" data-bo-price-preview-target="taxRule">
                                    {% for t in available_tax_rules %}
                                        <option value="{{ t.id }}">{{ t.title }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-3 mb-3">
                                {{ form_label(create_form.weight) }}
                                {{ form_widget(create_form.weight, { attr: { class: 'form-control', step: 0.01 } }) }}
                            </div>
                            <div class="col-md-3 mb-3">
                                {{ form_label(create_form.quantity) }}
                                {{ form_widget(create_form.quantity, { attr: { class: 'form-control' } }) }}
                            </div>
                        </div>
                        {{ form_widget(create_form.locale) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="product-create-submit">{{ 'Create'|trans }}</button>
                    </div>
                {{ form_end(create_form, { render_rest: false }) }}
            </div>
        </div>
    </div>

    <div class="modal fade" id="product-delete-modal" tabindex="-1" aria-labelledby="product-delete-modal-title" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-product-id"
         data-bo-prefill-modal-target-input-value="product_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.products.delete') }}?_token={{ assignToken() }}" method="post" data-testid="product-delete-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="product-delete-modal-title">{{ 'Delete product'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this product?'|trans }}</p>
                        <input type="hidden" name="product_id" value="" data-bo-prefill-modal-target="input">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" data-testid="product-delete-submit">{{ 'Delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="product-clone-modal" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-product-id"
         data-bo-prefill-modal-target-input-value="thelia_product_clone[productId]">
        <div class="modal-dialog">
            <div class="modal-content">
                {{ form_start(clone_form, { action: path('admin.products.clone'), method: 'post', attr: { 'data-testid': 'product-clone-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5">{{ 'Clone product'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            {{ form_label(clone_form.newRef) }}
                            {{ form_widget(clone_form.newRef, { attr: { class: 'form-control' } }) }}
                        </div>
                        {{ form_widget(clone_form.productId) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="product-clone-submit">{{ 'Clone'|trans }}</button>
                    </div>
                {{ form_end(clone_form) }}
            </div>
        </div>
    </div>
{% endblock %}
