{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Brands'|trans }}{% endblock %}
{% block body_testid %}catalog-brands{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Brands'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('brands.top') }}

    <div class="container-fluid" data-testid="brands-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Brands management'|trans }}</h1>
            <div class="d-flex gap-2">
                {% if is_granted('CREATE', 'admin.brand') %}
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#brand-create-modal" data-testid="brand-create-button">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        {{ 'Add a new brand'|trans }}
                    </button>
                {% endif %}
            </div>
        </div>

        {{ component('BoDataTable', {
            id: 'brands',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'Title'|trans),
                column_toggle('visible', 'Online'|trans, 'toggle_visible_url'),
                column('position', 'Position'|trans, 'center'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No brand defined yet.'|trans,
            tbodyAttributes: {
                'data-controller': 'bo-sortable',
                'data-bo-sortable-url-value': update_position_url,
                'data-bo-sortable-token-value': update_position_token,
                'data-bo-sortable-param-name-value': 'brand_id',
            },
        }) }}
    </div>

    {{ safe_hook('brands.bottom') }}

    {% include '@BackOfficeDefaultTwig/catalog/brand/_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/catalog/brand/_delete_modal.html.twig' %}
{% endblock %}

{% block scripts_extra %}
    {{ safe_hook('brands.js') }}
{% endblock %}
