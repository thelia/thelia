{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit brand'|trans }} — {{ brand.title }}{% endblock %}
{% block body_testid %}catalog-brand-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.brand.default') }}">{{ 'Brands'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ brand.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('brand.top', { brand: brand.id }) }}

    <div class="container-fluid" data-testid="brand-edit-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Brand'|trans }} <small class="text-muted">#{{ brand.id }}</small></h1>
            <a href="{{ path('admin.brand.default') }}" class="btn btn-outline-secondary" data-testid="brand-edit-back">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'Back to list'|trans }}
            </a>
        </div>

        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'general' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-general" type="button" role="tab" data-testid="brand-tab-general">
                    {{ 'General'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'seo' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-seo" type="button" role="tab" data-testid="brand-tab-seo">
                    {{ 'SEO'|trans }}
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade {% if current_tab == 'general' %}show active{% endif %}" id="tab-general" role="tabpanel">
                {{ form_start(form, { action: path('admin.brand.save', { brand_id: brand.id }), method: 'post', attr: { 'data-testid': 'brand-edit-form' } }) }}
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                {{ form_label(form.title) }}
                                {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                                {{ form_errors(form.title) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.chapo) }}
                                {{ form_widget(form.chapo, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.description) }}
                                {{ form_widget(form.description, { attr: { class: 'form-control', rows: 8 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.postscriptum) }}
                                {{ form_widget(form.postscriptum, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mb-3">
                                {{ form_widget(form.visible, { attr: { class: 'form-check-input' } }) }}
                                {{ form_label(form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.logo_image_id) }}
                                {{ form_widget(form.logo_image_id, { attr: { class: 'form-control' } }) }}
                                <small class="form-text text-muted">{{ 'Set the brand logo image ID. Brand images management is exposed via the legacy endpoints.'|trans }}</small>
                            </div>
                        </div>
                    </div>
                    {{ form_widget(form.id) }}
                    {{ form_widget(form.locale) }}
                    {{ safe_hook('brand.update-form', { brand: brand.id }) }}
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary" data-testid="brand-edit-submit">
                            <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>

            <div class="tab-pane fade {% if current_tab == 'seo' %}show active{% endif %}" id="tab-seo" role="tabpanel">
                {{ form_start(seo_form, { action: path('admin.brand.seo.save'), method: 'post', attr: { 'data-testid': 'brand-seo-form' } }) }}
                    <div class="mb-3">
                        {{ form_label(seo_form.url) }}
                        {{ form_widget(seo_form.url, { attr: { class: 'form-control' } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_title) }}
                        {{ form_widget(seo_form.meta_title, { attr: { class: 'form-control' } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_description) }}
                        {{ form_widget(seo_form.meta_description, { attr: { class: 'form-control', rows: 3 } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_keywords) }}
                        {{ form_widget(seo_form.meta_keywords, { attr: { class: 'form-control', rows: 3 } }) }}
                    </div>
                    {{ form_widget(seo_form.id) }}
                    {{ form_widget(seo_form.locale) }}
                    {{ safe_hook('brand.seo.update-form', { brand: brand.id }) }}
                    <button type="submit" class="btn btn-primary" data-testid="brand-seo-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save SEO'|trans }}
                    </button>
                {{ form_end(seo_form) }}
            </div>
        </div>
    </div>

    {{ safe_hook('brand.bottom', { brand: brand.id }) }}
{% endblock %}
