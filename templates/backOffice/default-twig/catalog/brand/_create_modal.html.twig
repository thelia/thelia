<div class="modal fade" id="brand-create-modal" tabindex="-1" aria-labelledby="brand-create-modal-title" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            {{ form_start(create_form, { action: path('admin.brand.create'), method: 'post', attr: { 'data-testid': 'brand-create-form' } }) }}
                <div class="modal-header">
                    <h2 class="modal-title h5" id="brand-create-modal-title">{{ 'Create a new brand'|trans }}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        {{ form_label(create_form.title) }}
                        {{ form_widget(create_form.title, { attr: { class: 'form-control', 'data-testid': 'brand-create-title' } }) }}
                        {{ form_errors(create_form.title) }}
                    </div>
                    <div class="form-check mb-3">
                        {{ form_widget(create_form.visible, { attr: { class: 'form-check-input', 'data-testid': 'brand-create-visible' } }) }}
                        {{ form_label(create_form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                    </div>
                    {{ form_widget(create_form.locale) }}
                    {{ safe_hook('brand.create-form') }}
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    <button type="submit" class="btn btn-primary" data-testid="brand-create-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Create'|trans }}
                    </button>
                </div>
            {{ form_end(create_form) }}
        </div>
    </div>
</div>
