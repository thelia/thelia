{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit category'|trans }} — {{ category.title }}{% endblock %}
{% block body_testid %}catalog-category-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.categories.default') }}">{{ 'Catalog'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ category.title }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('category.top', { category: category.id }) }}

    <div class="container-fluid" data-testid="category-edit-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Category'|trans }} <small class="text-muted">#{{ category.id }}</small></h1>
            <a href="{{ path('admin.categories.default', { category_id: category.parent }) }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> {{ 'Back'|trans }}
            </a>
        </div>

        <ul class="nav nav-tabs mb-3" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'general' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-general" type="button" data-testid="category-tab-general">
                    {{ 'General'|trans }}
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'children' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-children" type="button" data-testid="category-tab-children">
                    {{ 'Subcategories'|trans }} <span class="badge bg-secondary">{{ children|length }}</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'associations' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-associations" type="button" data-testid="category-tab-associations">
                    {{ 'Related content'|trans }} <span class="badge bg-secondary">{{ assigned_contents|length }}</span>
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link {% if current_tab == 'seo' %}active{% endif %}" data-bs-toggle="tab" data-bs-target="#tab-seo" type="button" data-testid="category-tab-seo">
                    {{ 'SEO'|trans }}
                </button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade {% if current_tab == 'general' %}show active{% endif %}" id="tab-general" role="tabpanel">
                {{ form_start(form, { action: path('admin.categories.save', { category_id: category.id }), method: 'post', attr: { 'data-testid': 'category-edit-form' } }) }}
                    <input type="hidden" name="category_id" value="{{ category.id }}">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                {{ form_label(form.title) }}
                                {{ form_widget(form.title, { attr: { class: 'form-control' } }) }}
                                {{ form_errors(form.title) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.chapo) }}
                                {{ form_widget(form.chapo, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.description) }}
                                {{ form_widget(form.description, { attr: { class: 'form-control', rows: 8 } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.postscriptum) }}
                                {{ form_widget(form.postscriptum, { attr: { class: 'form-control', rows: 3 } }) }}
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-check mb-3">
                                {{ form_widget(form.visible, { attr: { class: 'form-check-input' } }) }}
                                {{ form_label(form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.parent) }}
                                {{ form_widget(form.parent, { attr: { class: 'form-control' } }) }}
                            </div>
                            <div class="mb-3">
                                {{ form_label(form.default_template_id) }}
                                <select name="{{ form.default_template_id.vars.full_name }}" class="form-select" data-testid="category-default-template">
                                    {% for template in available_templates %}
                                        <option value="{{ template.id }}" {% if template.id == category.defaultTemplateId %}selected{% endif %}>{{ template.name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                        </div>
                    </div>
                    {{ form_widget(form.id) }}
                    {{ form_widget(form.locale) }}
                    {{ safe_hook('category.update-form', { category: category.id }) }}
                    <button type="submit" class="btn btn-primary" data-testid="category-edit-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                    </button>
                {{ form_end(form, { render_rest: false }) }}
            </div>

            <div class="tab-pane fade {% if current_tab == 'children' %}show active{% endif %}" id="tab-children" role="tabpanel">
                <a href="{{ path('admin.categories.default', { category_id: category.id }) }}" class="btn btn-outline-primary mb-3">
                    <i class="bi bi-list" aria-hidden="true"></i> {{ 'Manage subcategories'|trans }}
                </a>
                <table class="table" data-testid="category-children-table">
                    <thead>
                        <tr>
                            <th>{{ 'Title'|trans }}</th>
                            <th class="text-center">{{ 'Online'|trans }}</th>
                            <th class="text-center">{{ 'Position'|trans }}</th>
                            <th class="text-end">{{ 'Actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for child in children %}
                            <tr data-testid="category-child-row-{{ child.id }}">
                                <td>{{ child.title }}</td>
                                <td class="text-center">{% if child.visible %}<i class="bi bi-check2 text-success"></i>{% else %}<i class="bi bi-x text-danger"></i>{% endif %}</td>
                                <td class="text-center">{{ child.position }}</td>
                                <td class="text-end">
                                    <a href="{{ child.edit_url }}" class="btn btn-sm btn-outline-secondary" data-testid="category-child-edit-{{ child.id }}">
                                        <i class="bi bi-pencil" aria-hidden="true"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="4" class="text-muted text-center">{{ 'No subcategory.'|trans }}</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="tab-pane fade {% if current_tab == 'associations' %}show active{% endif %}" id="tab-associations" role="tabpanel" data-testid="category-associations-tab">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body"
                         data-controller="bo-folder-content-picker"
                         data-bo-folder-content-picker-url-template-value="{{ available_related_content_url }}">
                        <h2 class="h5 mb-1">{{ 'Related content'|trans }}</h2>
                        <p class="text-muted">{{ 'You can attach here some content to this category'|trans }}</p>

                        {% if folder_tree|length > 0 %}
                            <form action="{{ path('admin.categories.related-content.add') }}" method="post" class="row g-3 align-items-end mb-3" data-testid="category-related-content-form">
                                <input type="hidden" name="category_id" value="{{ category.id }}">
                                <input type="hidden" name="current_tab" value="associations">
                                <input type="hidden" name="_token" value="{{ delete_related_content_token }}">
                                <div class="col-md-6">
                                    <label for="category-folder-id" class="form-label">{{ 'Folder'|trans }}</label>
                                    <select id="category-folder-id" name="folder_id" class="form-select"
                                            data-bo-folder-content-picker-target="folder"
                                            data-action="change->bo-folder-content-picker#folderChanged">
                                        <option value="">{{ 'Select a folder...'|trans }}</option>
                                        {% for folder in folder_tree %}
                                            <option value="{{ folder.id }}" {% if folder.id == selected_folder_id %}selected{% endif %} style="padding-left: {{ 3 + folder.level * 20 }}px">{{ folder.title }}</option>
                                        {% endfor %}
                                    </select>
                                    <small class="form-text text-muted">{{ 'Select a folder to get its content'|trans }}</small>
                                </div>
                                <div class="col-md-6">
                                    <div data-bo-folder-content-picker-target="picker" class="d-none">
                                        <label for="category-content-id" class="form-label">{{ 'Content'|trans }}</label>
                                        <div class="input-group">
                                            <select id="category-content-id" name="content_id" class="form-select" required
                                                    data-bo-folder-content-picker-target="content">
                                                <option value="">{{ 'Select a folder content...'|trans }}</option>
                                            </select>
                                            <button type="submit" class="btn btn-primary" data-testid="category-related-content-add">
                                                <i class="bi bi-plus-lg" aria-hidden="true"></i>
                                            </button>
                                        </div>
                                        <small class="form-text text-muted">{{ 'Select a content and click + to add it to this category'|trans }}</small>
                                    </div>
                                    <div data-bo-folder-content-picker-target="empty" class="d-none alert alert-info mb-0">{{ 'No available content in this folder'|trans }}</div>
                                </div>
                            </form>
                        {% else %}
                            <div class="alert alert-info">{{ 'No folders found'|trans }}</div>
                        {% endif %}

                        <div class="table-responsive">
                            <table class="table align-middle" data-testid="category-related-content-table">
                                <thead>
                                    <tr>
                                        <th style="width: 80px;">{{ 'ID'|trans }}</th>
                                        <th>{{ 'Content title'|trans }}</th>
                                        {{ safe_hook('category.contents-table-header', { category_id: category.id }) }}
                                        <th class="text-end" style="width: 100px;">{{ 'Actions'|trans }}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for content in assigned_contents %}
                                        <tr data-testid="category-related-content-row-{{ content.id }}">
                                            <td>{{ content.id }}</td>
                                            <td><a href="{{ content.url }}">{{ content.title }}</a></td>
                                            {{ safe_hook('category.contents-table-row', { category_id: category.id, content_id: content.id }) }}
                                            <td class="text-end">
                                                {% if is_granted('UPDATE', 'admin.category') %}
                                                    <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#category-related-content-delete" data-content-id="{{ content.id }}" data-content-label="{{ content.title }}" data-testid="category-related-content-delete-{{ content.id }}">
                                                        <i class="bi bi-trash" aria-hidden="true"></i>
                                                    </button>
                                                {% endif %}
                                            </td>
                                        </tr>
                                    {% else %}
                                        <tr><td colspan="3" class="text-muted text-center">{{ 'This category contains no contents'|trans }}</td></tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                {{ safe_hook('category.tab-content', { category_id: category.id }) }}

                <div class="modal fade" id="category-related-content-delete" tabindex="-1" aria-hidden="true"
                     data-controller="bo-prefill-modal"
                     data-bo-prefill-modal-source-trigger-value="data-content-id"
                     data-bo-prefill-modal-target-input-value="content_id">
                    <div class="modal-dialog">
                        <form method="post" action="{{ path('admin.categories.related-content.delete') }}?_token={{ delete_related_content_token }}" class="modal-content" data-testid="category-related-content-delete-form">
                            <div class="modal-header">
                                <h5 class="modal-title">{{ 'Remove related content'|trans }}</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                            </div>
                            <div class="modal-body">
                                <p>{{ 'Do you really want to remove this related content ?'|trans }}</p>
                                <input type="hidden" name="category_id" value="{{ category.id }}">
                                <input type="hidden" name="content_id" value="" data-bo-prefill-modal-target="input">
                                <input type="hidden" name="current_tab" value="associations">
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                                <button type="submit" class="btn btn-danger">{{ 'Confirm'|trans }}</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade {% if current_tab == 'seo' %}show active{% endif %}" id="tab-seo" role="tabpanel">
                {{ form_start(seo_form, { action: path('admin.categories.seo.save'), method: 'post', attr: { 'data-testid': 'category-seo-form' } }) }}
                    <div class="mb-3">
                        {{ form_label(seo_form.url) }}
                        {{ form_widget(seo_form.url, { attr: { class: 'form-control' } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_title) }}
                        {{ form_widget(seo_form.meta_title, { attr: { class: 'form-control' } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_description) }}
                        {{ form_widget(seo_form.meta_description, { attr: { class: 'form-control', rows: 3 } }) }}
                    </div>
                    <div class="mb-3">
                        {{ form_label(seo_form.meta_keywords) }}
                        {{ form_widget(seo_form.meta_keywords, { attr: { class: 'form-control', rows: 3 } }) }}
                    </div>
                    {{ form_widget(seo_form.id) }}
                    {{ form_widget(seo_form.locale) }}
                    {{ safe_hook('category.seo.update-form', { category: category.id }) }}
                    <button type="submit" class="btn btn-primary" data-testid="category-seo-submit">
                        <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save SEO'|trans }}
                    </button>
                {{ form_end(seo_form) }}
            </div>
        </div>
    </div>

    {{ safe_hook('category.bottom', { category: category.id }) }}
{% endblock %}
