{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Categories'|trans }}{% endblock %}
{% block body_testid %}catalog-categories{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.categories.default') }}">{{ 'Catalog'|trans }}</a></li>
            {% for crumb in breadcrumb_path %}
                {% if loop.last %}
                    <li class="breadcrumb-item active" aria-current="page">{{ crumb.title }}</li>
                {% else %}
                    <li class="breadcrumb-item"><a href="{{ path('admin.categories.default', { category_id: crumb.id }) }}">{{ crumb.title }}</a></li>
                {% endif %}
            {% endfor %}
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('catalog.top') }}

    <div class="container-fluid" data-testid="categories-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Categories'|trans }}</h1>
            <div class="d-flex gap-2">
                <a href="{{ path('admin.categories.tree') }}" class="btn btn-outline-secondary" data-testid="category-tree-link">
                    <i class="bi bi-diagram-3" aria-hidden="true"></i> {{ 'Tree view'|trans }}
                </a>
                {% if parent_id > 0 %}
                    <a href="{{ path('admin.categories.update', { category_id: parent_id }) }}" class="btn btn-outline-secondary" data-testid="category-edit-parent">
                        <i class="bi bi-pencil-square" aria-hidden="true"></i> {{ 'Edit this category'|trans }}
                    </a>
                {% endif %}
                {% if is_granted('CREATE', 'admin.category') %}
                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#category-create-modal" data-testid="category-create-button">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i>
                        {{ 'Add a new category'|trans }}
                    </button>
                {% endif %}
            </div>
        </div>

        {{ component('BoDataTable', {
            id: 'categories',
            columns: [
                column('id', 'ID'|trans),
                column('title', 'Title'|trans),
                column_toggle('visible', 'Online'|trans, 'toggle_visible_url'),
                column('position', 'Position'|trans, 'center'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No subcategory yet.'|trans,
            tbodyAttributes: {
                'data-controller': 'bo-sortable',
                'data-bo-sortable-url-value': update_position_url,
                'data-bo-sortable-token-value': update_position_token,
                'data-bo-sortable-param-name-value': 'category_id',
            },
        }) }}

        {% for row in rows %}
            <div class="d-none">
                <a href="{{ row.children_url }}" data-testid="category-children-link-{{ row.id }}">{{ 'Subcategories'|trans }}</a>
            </div>
        {% endfor %}
    </div>

    {{ safe_hook('catalog.bottom') }}

    <div class="modal fade" id="category-create-modal" tabindex="-1" aria-labelledby="category-create-modal-title" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                {{ form_start(create_form, { action: path('admin.categories.create'), method: 'post', attr: { 'data-testid': 'category-create-form' } }) }}
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="category-create-modal-title">{{ 'Create a new category'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            {{ form_label(create_form.title) }}
                            {{ form_widget(create_form.title, { attr: { class: 'form-control' } }) }}
                            {{ form_errors(create_form.title) }}
                        </div>
                        <div class="form-check mb-3">
                            {{ form_widget(create_form.visible, { attr: { class: 'form-check-input' } }) }}
                            {{ form_label(create_form.visible, null, { label_attr: { class: 'form-check-label' } }) }}
                        </div>
                        {{ form_widget(create_form.locale) }}
                        {{ form_widget(create_form.parent) }}
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-primary" data-testid="category-create-submit">{{ 'Create'|trans }}</button>
                    </div>
                {{ form_end(create_form) }}
            </div>
        </div>
    </div>

    <div class="modal fade" id="category-delete-modal" tabindex="-1" aria-labelledby="category-delete-modal-title" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-category-id"
         data-bo-prefill-modal-target-input-value="category_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.categories.delete') }}?_token={{ assignToken() }}" method="post" data-testid="category-delete-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5" id="category-delete-modal-title">{{ 'Delete category'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this category? Subcategories and products are not deleted but become orphaned.'|trans }}</p>
                        <input type="hidden" name="category_id" value="" data-bo-prefill-modal-target="input">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" data-testid="category-delete-submit">{{ 'Delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
