{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Category tree'|trans }}{% endblock %}
{% block body_testid %}catalog-category-tree{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.categories.default') }}">{{ 'Catalog'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Tree'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('catalog.tree.top') }}

    <div class="container-fluid" data-testid="category-tree-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Category tree'|trans }}</h1>
            <a href="{{ path('admin.categories.default') }}" class="btn btn-outline-secondary" data-testid="category-tree-back">
                <i class="bi bi-list" aria-hidden="true"></i> {{ 'Flat view'|trans }}
            </a>
        </div>

        <p class="text-muted small">{{ 'Drag a category onto another to move it as a child. Drag onto the root drop zone to move it to top level.'|trans }}</p>

        <div class="card" data-controller="bo-category-tree"
             data-bo-category-tree-move-url-value="{{ path('admin.categories.move') }}"
             data-bo-category-tree-token-value="{{ token }}">
            <div class="card-body p-3">
                <ul class="bo-category-tree list-unstyled mb-0" data-bo-category-tree-target="root" data-parent-id="0" data-testid="category-tree-root">
                    {% if tree is empty %}
                        <li class="text-muted small py-3 text-center" data-testid="category-tree-empty">{{ 'No category yet.'|trans }}</li>
                    {% else %}
                        {% include '@BackOfficeDefaultTwig/catalog/category/_tree_nodes.html.twig' with { items: tree, depth: 0 } only %}
                    {% endif %}
                </ul>
            </div>
        </div>
    </div>

    {{ safe_hook('catalog.tree.bottom') }}
{% endblock %}
