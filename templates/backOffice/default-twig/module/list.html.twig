{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Modules'|trans }}{% endblock %}
{% block body_testid %}modules-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Modules'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('modules.top') }}

    <div class="container-fluid" data-testid="modules-page">
        <h1 class="h3 mb-3">{{ 'Modules management'|trans }}</h1>

        {{ component('BoDataTable', {
            id: 'modules',
            columns: [
                column('id', 'ID'|trans),
                column('code', 'Code'|trans),
                column('title', 'Title'|trans),
                column('type', 'Type'|trans),
                column('version', 'Version'|trans),
                column_toggle('activated', 'Active'|trans, 'toggle_url'),
                column('position', 'Position'|trans, 'center'),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No module installed.'|trans,
            tbodyAttributes: {
                'data-controller': 'bo-sortable',
                'data-bo-sortable-url-value': update_position_url,
                'data-bo-sortable-token-value': update_position_token,
                'data-bo-sortable-param-name-value': 'module_id',
            },
        }) }}

        <form action="{{ path('admin.module.install') }}" method="post" enctype="multipart/form-data" class="mt-4" data-testid="module-install-form">
            <input type="hidden" name="_token" value="{{ assignToken() }}">
            <div class="row g-2 align-items-center">
                <div class="col-md-8">
                    <label class="form-label">{{ 'Install a new module from a .zip file'|trans }}</label>
                    <input type="file" name="module" class="form-control" data-testid="module-install-file" accept=".zip" required>
                    <div class="form-text small">{{ 'The archive must contain a single root directory matching the module code.'|trans }}</div>
                </div>
                <div class="col-md-4 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100" data-testid="module-install-submit">
                        <i class="bi bi-cloud-upload" aria-hidden="true"></i> {{ 'Install'|trans }}
                    </button>
                </div>
            </div>
        </form>
    </div>

    <div class="modal fade" id="module-delete-modal" tabindex="-1" aria-hidden="true"
         data-controller="bo-prefill-modal"
         data-bo-prefill-modal-source-trigger-value="data-module-id"
         data-bo-prefill-modal-target-input-value="module_id">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('admin.module.delete') }}?_token={{ assignToken() }}" method="post" data-testid="module-delete-form">
                    <div class="modal-header">
                        <h2 class="modal-title h5">{{ 'Delete module'|trans }}</h2>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>{{ 'Do you really want to delete this module?'|trans }}</p>
                        <input type="hidden" name="module_id" value="" data-bo-prefill-modal-target="input">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" data-testid="module-delete-submit">{{ 'Delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
