{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit module hook'|trans }}{% endblock %}
{% block body_testid %}module-hook-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.module-hook') }}">{{ 'Module hooks'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">#{{ module_hook.id }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="module-hook-edit-page">
        <h1 class="h3 mb-3">{{ 'Edit module hook'|trans }} <small class="text-muted">#{{ module_hook.id }}</small></h1>

        <form action="{{ path('admin.module-hook.save', { module_hook_id: module_hook.id }) }}" method="post" data-testid="module-hook-edit-form">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">{{ 'Module'|trans }}</label>
                    <select name="module_id" class="form-select">
                        {% for m in available_modules %}
                            <option value="{{ m.id }}" {% if m.id == module_hook.moduleId %}selected{% endif %}>{{ m.code }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">{{ 'Hook'|trans }}</label>
                    <select name="hook_id" class="form-select">
                        {% for h in available_hooks %}
                            <option value="{{ h.id }}" {% if h.id == module_hook.hookId %}selected{% endif %}>{{ h.code }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">{{ 'Class name'|trans }}</label>
                    <input type="text" name="classname" value="{{ module_hook.classname }}" class="form-control">
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">{{ 'Method'|trans }}</label>
                    <input type="text" name="method" value="{{ module_hook.method }}" class="form-control">
                </div>
                <div class="col-md-12 mb-3">
                    <label class="form-label">{{ 'Templates'|trans }}</label>
                    <input type="text" name="templates" value="{{ module_hook.templates }}" class="form-control">
                </div>
                <div class="col-md-12 form-check mb-3">
                    <input type="checkbox" name="active" value="1" {% if module_hook.active %}checked{% endif %} class="form-check-input">
                    <label class="form-check-label">{{ 'Active'|trans }}</label>
                </div>
            </div>
            <button type="submit" class="btn btn-primary" data-testid="module-hook-edit-submit">{{ 'Save'|trans }}</button>
            <a href="{{ path('admin.module-hook') }}" class="btn btn-outline-secondary">{{ 'Back'|trans }}</a>
        </form>
    </div>
{% endblock %}
