{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Module hooks'|trans }}{% endblock %}
{% block body_testid %}module-hooks-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.module') }}">{{ 'Modules'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Module hooks'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="module-hooks-page">
        <h1 class="h3 mb-3">{{ 'Module hooks management'|trans }}</h1>

        <form action="{{ path('admin.module-hook.create') }}" method="post" class="card p-3 mb-4" data-testid="module-hook-create-form">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">{{ 'Module'|trans }}</label>
                    <select name="module_id" class="form-select" data-testid="module-hook-module">
                        {% for m in available_modules %}
                            <option value="{{ m.id }}">{{ m.code }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">{{ 'Hook'|trans }}</label>
                    <select name="hook_id" class="form-select" data-testid="module-hook-hook">
                        {% for h in available_hooks %}
                            <option value="{{ h.id }}">{{ h.code }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">{{ 'Class'|trans }}</label>
                    <input type="text" name="classname" class="form-control" data-testid="module-hook-classname">
                </div>
                <div class="col-md-2">
                    <label class="form-label">{{ 'Method'|trans }}</label>
                    <input type="text" name="method" class="form-control" data-testid="module-hook-method">
                </div>
                <div class="col-md-1 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100" data-testid="module-hook-create-submit">{{ 'Add'|trans }}</button>
                </div>
            </div>
        </form>

        <table class="table" data-testid="module-hooks-table">
            <thead>
                <tr>
                    <th>{{ 'ID'|trans }}</th>
                    <th>{{ 'Module'|trans }}</th>
                    <th>{{ 'Hook'|trans }}</th>
                    <th>{{ 'Class'|trans }}</th>
                    <th>{{ 'Method'|trans }}</th>
                    <th class="text-center">{{ 'Active'|trans }}</th>
                    <th class="text-center">{{ 'Position'|trans }}</th>
                    <th class="text-end">{{ 'Actions'|trans }}</th>
                </tr>
            </thead>
            <tbody data-controller="bo-sortable"
                   data-bo-sortable-url-value="{{ update_position_url }}"
                   data-bo-sortable-token-value="{{ update_position_token }}"
                   data-bo-sortable-param-name-value="module_hook_id">
                {% for row in rows %}
                    <tr data-id="{{ row.id }}" data-testid="module-hook-row-{{ row.id }}">
                        <td>{{ row.id }}</td>
                        <td>{{ row.module }}</td>
                        <td>{{ row.hook }}</td>
                        <td>{{ row.classname }}</td>
                        <td>{{ row.method }}</td>
                        <td class="text-center">{% if row.active %}<i class="bi bi-check2 text-success"></i>{% else %}<i class="bi bi-x text-danger"></i>{% endif %}</td>
                        <td class="text-center">{{ row.position }}</td>
                        <td class="text-end">
                            <a href="{{ row.edit_url }}" class="btn btn-sm btn-outline-secondary" data-testid="module-hook-edit-{{ row.id }}">
                                <i class="bi bi-pencil" aria-hidden="true"></i>
                            </a>
                            <a href="{{ row.toggle_url }}" class="btn btn-sm btn-outline-secondary" data-testid="module-hook-toggle-{{ row.id }}">
                                <i class="bi bi-power" aria-hidden="true"></i>
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="text-muted text-center">{{ 'No module hook yet.'|trans }}</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
