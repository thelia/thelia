{{ safe_hook(kind == 'image' ? 'tab-image.top' : 'tab-document.top', { id: parent_id, type: parent_type }) }}

<div class="bo-file-upload card mb-3" data-controller="bo-file-upload"
     data-bo-file-upload-save-url-value="{{ path(urls.save, { parentType: parent_type, parentId: parent_id }) }}"
     data-bo-file-upload-list-url-value="{{ path(urls.list, { parentType: parent_type, parentId: parent_id }) }}">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data" class="d-flex flex-column gap-2"
              data-testid="bo-file-upload-form-{{ kind }}"
              data-action="submit->bo-file-upload#submit">
            <input type="file" name="file" class="form-control" required
                   data-bo-file-upload-target="input"
                   accept="{{ kind == 'image' ? 'image/*' : '*' }}">
            <button type="submit" class="btn btn-primary align-self-start" data-testid="bo-file-upload-submit-{{ kind }}">
                <i class="bi bi-cloud-upload" aria-hidden="true"></i>
                {% if kind == 'image' %}{{ 'Upload images'|trans }}{% else %}{{ 'Upload documents'|trans }}{% endif %}
            </button>
        </form>
        <div class="mt-3" data-bo-file-upload-target="status" hidden></div>
    </div>
</div>

<div data-bo-file-upload-target="list">
    {% include '@BackOfficeDefaultTwig/file/_list.html.twig' with {
        kind: kind,
        parent_type: parent_type,
        parent_id: parent_id,
        items: [],
        can_update: true,
        can_delete: true,
        urls: urls,
    } only %}
</div>

{{ safe_hook(kind == 'image' ? 'tab-image.bottom' : 'tab-document.bottom', { id: parent_id, type: parent_type }) }}
