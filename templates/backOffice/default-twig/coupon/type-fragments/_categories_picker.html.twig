<div class="mb-3" data-testid="coupon-categories-picker">
    <label for="coupon-categories" class="form-label">{{ 'Applicable categories'|trans }}</label>
    <select id="coupon-categories" class="form-select" name="coupon_specific[categories][]" multiple size="8"
            data-testid="coupon-categories-select">
        {% for cat in categories %}
            <option value="{{ cat.id }}" {% if cat.id in selected_categories %}selected{% endif %}>{{ cat.title }}</option>
        {% endfor %}
    </select>
    <div class="form-text small">{{ 'Hold Ctrl/Cmd to select multiple categories.'|trans }}</div>
</div>
