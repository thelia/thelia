<div data-controller="bo-coupon-product-picker"
     data-bo-coupon-product-picker-data-value="{{ products_by_category|json_encode|e('html_attr') }}"
     data-testid="coupon-products-picker">
    <div class="row">
        <div class="col-md-6 mb-3">
            <label for="coupon-category" class="form-label">{{ 'Filter by category'|trans }}</label>
            <select id="coupon-category" class="form-select" name="coupon_specific[category_id]"
                    data-bo-coupon-product-picker-target="category"
                    data-action="change->bo-coupon-product-picker#onCategoryChangeMulti">
                <option value="">— {{ 'All products'|trans }} —</option>
                {% for cat in categories %}
                    <option value="{{ cat.id }}">{{ cat.title }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="col-md-6 mb-3">
            <label for="coupon-products" class="form-label">{{ 'Applicable products'|trans }}</label>
            <select id="coupon-products" class="form-select" name="coupon_specific[products][]" multiple size="8"
                    data-bo-coupon-product-picker-target="productMulti"
                    data-bo-coupon-product-picker-initial-multi-value="{{ selected_products|json_encode|e('html_attr') }}"
                    data-testid="coupon-products-select">
                {% for catProducts in products_by_category %}
                    {% for product in catProducts %}
                        <option value="{{ product.id }}" {% if product.id in selected_products %}selected{% endif %}>{{ product.title }}</option>
                    {% endfor %}
                {% endfor %}
            </select>
        </div>
    </div>
</div>
