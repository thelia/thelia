<div class="mb-3" data-testid="coupon-percent-input">
    <label for="coupon-percent" class="form-label">{{ 'Percent Discount'|trans }}</label>
    <div class="input-group">
        <input id="coupon-percent" type="number" step="any" min="0" class="form-control" name="coupon_specific[percentage]" value="{{ percentage_value|default('') }}" placeholder="5">
        <span class="input-group-text">%</span>
    </div>
</div>
