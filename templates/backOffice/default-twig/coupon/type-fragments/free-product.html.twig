<div class="row mb-3" data-controller="bo-coupon-product-picker">
    <div class="col-md-6">
        <label for="coupon-offered-category" class="form-label">{{ 'Offered category'|trans }}</label>
        <select id="coupon-offered-category" class="form-select" name="coupon_specific[offered_category_id]"
                data-bo-coupon-product-picker-target="category"
                data-action="change->bo-coupon-product-picker#onCategoryChange"
                data-testid="coupon-free-product-category">
            <option value="">— {{ 'Select a category'|trans }} —</option>
            {% for cat in categories|default([]) %}
                <option value="{{ cat.id }}" {% if offered_category_id|default('') == cat.id %}selected{% endif %}>{{ cat.title }}</option>
            {% endfor %}
        </select>
    </div>
    <div class="col-md-6">
        <label for="coupon-offered-product" class="form-label">{{ 'Offered product'|trans }}</label>
        <select id="coupon-offered-product" class="form-select" name="coupon_specific[offered_product_id]"
                data-bo-coupon-product-picker-target="product"
                data-bo-coupon-product-picker-data-value="{{ products_by_category|default({})|json_encode|e('html_attr') }}"
                data-bo-coupon-product-picker-initial-product-value="{{ offered_product_id|default('') }}"
                data-testid="coupon-free-product-product">
            <option value="">— {{ 'Select a product'|trans }} —</option>
        </select>
    </div>
</div>
