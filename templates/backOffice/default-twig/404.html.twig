{% extends 'auth-layout.html.twig' %}

{% block title %}{{ '404 — Not found'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_title %}{{ '404'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_subtitle %}{{ 'Page not found'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_content %}
    <p class="text-body-secondary text-center mb-4" data-testid="not-found">
        {{ 'The page you are looking for does not exist or has been moved.'|trans({}, 'bo.default-twig') }}
    </p>

    <a href="{{ path('admin', {router: 'admin'}) }}" class="btn btn-primary w-100">
        <i class="bi bi-house me-2"></i>
        {{ 'Back to the dashboard'|trans({}, 'bo.default-twig') }}
    </a>
{% endblock %}
