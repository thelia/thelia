{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Export'|trans }}{% endblock %}
{% block body_testid %}export-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Export'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    <div class="container-fluid" data-testid="export-page">
        <h1 class="h3 mb-3">{{ 'Available exports'|trans }}</h1>

        {% if categories is empty %}
            <p class="text-muted">{{ 'No export defined.'|trans }}</p>
        {% else %}
            <div class="row g-4">
                {% for category in categories %}
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">{{ category.title }}</div>
                            <ul class="list-group list-group-flush">
                                {% for export in category.exports %}
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <strong>{{ export.title }}</strong>
                                            {% if export.description %}<div class="text-muted small">{{ export.description }}</div>{% endif %}
                                        </div>
                                        <a href="{{ path('export.view', { id: export.id }) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-download" aria-hidden="true"></i> {{ 'Export'|trans }}</a>
                                    </li>
                                {% else %}
                                    <li class="list-group-item text-muted small">{{ 'No export in this category.'|trans }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
