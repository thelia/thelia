{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Orders'|trans }}{% endblock %}
{% block body_testid %}order-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Orders'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('orders.top') }}

    <div class="container-fluid" data-testid="orders-page">
        <h1 class="h3 mb-3">{{ 'Orders management'|trans }}</h1>

        <form method="get" action="{{ path('admin.order.list') }}" class="row g-2 mb-3" data-testid="order-search-form">
            <div class="col-md-4">
                <label class="form-label">{{ 'Status'|trans }}</label>
                <select name="status_id" class="form-select" data-testid="order-filter-status">
                    {% for status in available_statuses %}
                        <option value="{{ status.id }}" {% if status.id == current_status %}selected{% endif %}>{{ status.title }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">{{ 'Reference / transaction'|trans }}</label>
                <input type="search" name="q" value="{{ current_search }}" class="form-control" data-testid="order-search-input">
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-secondary" data-testid="order-search-submit">{{ 'Search'|trans }}</button>
                <a href="{{ path('admin.order.list') }}" class="btn btn-outline-secondary">{{ 'Reset'|trans }}</a>
            </div>
        </form>

        {{ component('BoDataTable', {
            id: 'orders',
            columns: [
                column('id', 'ID'|trans),
                column('ref', 'Reference'|trans),
                column('status', 'Status'|trans),
                column('total', 'Total'|trans, 'end'),
                column('currency', 'Currency'|trans, 'center'),
                column('date', 'Date'|trans),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No order matches the current filters.'|trans,
        }) }}

        {% if pages > 1 %}
            <nav aria-label="{{ 'Order pagination'|trans }}" data-testid="order-pagination">
                <ul class="pagination">
                    {% for p in 1..pages %}
                        <li class="page-item {% if p == current_page %}active{% endif %}">
                            <a class="page-link" href="?{% if current_status > 0 %}status_id={{ current_status }}&{% endif %}{% if current_search %}q={{ current_search }}&{% endif %}page={{ p }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        {% endif %}
    </div>

    {{ safe_hook('orders.bottom') }}
{% endblock %}
