{% extends '@BackOfficeDefaultTwig/auth-layout.html.twig' %}

{% block title %}{{ 'Lost password'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_title %}{{ 'Lost password'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_subtitle %}{{ 'Recover your back-office credentials'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_content %}
    {% if create_request_success|default(false) %}
        <div class="alert alert-success" role="alert" data-testid="lost-password-success">
            {{ 'A link to reset your password has been sent to your email address.'|trans }}
        </div>
        <a href="{{ path('admin.login') }}" class="btn btn-outline-primary w-100" data-testid="lost-password-back-login">
            <i class="bi bi-arrow-left me-2"></i>{{ 'Back to login'|trans }}
        </a>
    {% elseif token_error|default(false) %}
        <div class="alert alert-danger" role="alert" data-testid="lost-password-token-error">
            {{ 'The provided token is invalid or has expired.'|trans }}
        </div>
        <a href="{{ path('admin.lost-password') }}" class="btn btn-outline-primary w-100">
            <i class="bi bi-arrow-clockwise me-2"></i>{{ 'Request a new link'|trans }}
        </a>
    {% else %}
        {% if error %}
            <div class="alert alert-danger" role="alert" data-testid="lost-password-error">{{ error }}</div>
        {% endif %}

        <form method="POST" action="{{ path('admin.password-create') }}" data-testid="lost-password-form">
            <div class="mb-3">
                <label for="username_or_email" class="form-label">{{ 'Username or e-mail address'|trans }}</label>
                <input type="text" class="form-control form-control-lg" id="username_or_email" name="username_or_email" required minlength="3" autofocus>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
                <i class="bi bi-envelope me-2"></i>{{ 'Send recovery email'|trans }}
            </button>
        </form>

        <div class="text-center mt-3">
            <a class="text-decoration-none small" href="{{ path('admin.login') }}">
                <i class="bi bi-arrow-left me-1"></i>{{ 'Back to login'|trans }}
            </a>
        </div>
    {% endif %}
{% endblock %}
