{% extends '@BackOfficeDefaultTwig/auth-layout.html.twig' %}

{% block title %}{{ 'Create password'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_title %}{{ 'Create password'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_subtitle %}{{ 'Set a new password for your back-office account'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_content %}
    {% if error %}
        <div class="alert alert-danger" role="alert" data-testid="create-password-error">{{ error }}</div>
    {% endif %}

    <form method="POST" action="{{ path('admin.password-renewed') }}" data-testid="create-password-form">
        <div class="mb-3">
            <label for="password" class="form-label">{{ 'New password'|trans }}</label>
            <input type="password" class="form-control form-control-lg" id="password" name="password" required autofocus>
        </div>
        <div class="mb-3">
            <label for="password_confirm" class="form-label">{{ 'Confirm new password'|trans }}</label>
            <input type="password" class="form-control form-control-lg" id="password_confirm" name="password_confirm" required>
        </div>

        <button type="submit" class="btn btn-primary btn-lg w-100">
            <i class="bi bi-check-lg me-2"></i>{{ 'Save new password'|trans }}
        </button>
    </form>

    <div class="text-center mt-3">
        <a class="text-decoration-none small" href="{{ path('admin.login') }}">
            <i class="bi bi-arrow-left me-1"></i>{{ 'Back to login'|trans }}
        </a>
    </div>
{% endblock %}
