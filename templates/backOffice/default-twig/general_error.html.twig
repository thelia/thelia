{% extends 'auth-layout.html.twig' %}

{% block title %}{{ 'Error'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_title %}{{ 'Error'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block auth_subtitle %}{{ 'Something went wrong'|trans({}, 'bo.default-twig') }}{% endblock %}

{% block auth_content %}
    <div class="alert alert-danger" role="alert" data-testid="general-error">
        {{ error_message|default('An unexpected error occurred.'|trans({}, 'bo.default-twig')) }}
    </div>

    <a href="{{ path('admin', {router: 'admin'}) }}" class="btn btn-outline-primary w-100">
        <i class="bi bi-house me-2"></i>
        {{ 'Back to the dashboard'|trans({}, 'bo.default-twig') }}
    </a>
{% endblock %}
