{# Back-office Twig form theme — Bootstrap 5 layout with a few back-office
   refinements. The form theme is registered globally in twig.form_themes so it
   is applied to every form rendered by the active Twig environment, including
   front-office Flexy templates. To keep the front-office Flexy theme intact,
   each block short-circuits to the matching @formTwig/flexy_form_theme block
   when the current request path is not under /admin. Bootstrap_5_layout is
   referenced via block(...) rather than {% use %} so we do not accidentally
   re-export every Bootstrap block and shadow Flexy overrides. #}

{%- block form_widget_simple -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        {{- block('form_widget_simple', 'bootstrap_5_layout.html.twig') -}}
    {%- else -%}
        {{- block('form_widget_simple', '@formTwig/flexy_form_theme.html.twig') -}}
    {%- endif -%}
{%- endblock form_widget_simple -%}

{%- block form_label -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        {% if label is not same as(false) -%}
            {%- if compound is defined and compound -%}
                {%- set element = element|default('legend') -%}
                {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' col-form-label')|trim}) -%}
            {%- else -%}
                {%- set label_attr = label_attr|merge({for: id, class: (label_attr.class|default('') ~ ' form-label')|trim}) -%}
            {%- endif -%}
            {%- if required -%}
                {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' required')|trim}) -%}
            {%- endif -%}
            {%- if label is empty -%}
                {%- if label_format is not empty -%}
                    {%- set label = label_format|replace({
                        '%name%': name,
                        '%id%': id,
                    }) -%}
                {%- else -%}
                    {%- set label = name|humanize -%}
                {%- endif -%}
            {%- endif -%}
            <{{ element|default('label') }}{% with { attr: label_attr } %}{{ block('attributes', 'form_div_layout.html.twig') }}{% endwith %}>
                <span class="bo-form-label__text">{{ translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) }}</span>
                {%- if required %}<span class="bo-form-label__required" aria-hidden="true">*</span>{% endif -%}
                {%- if not required %}<small class="bo-form-label__optional text-body-secondary">({{ 'optional'|trans({}, 'core') }})</small>{% endif -%}
                {%- if help is not empty -%}
                    <small class="bo-form-label__help text-body-secondary">{{ translation_domain is same as(false) ? help : help|trans(help_translation_parameters, translation_domain) }}</small>
                {%- endif -%}
            </{{ element|default('label') }}>
        {%- endif -%}
    {%- else -%}
        {{- block('form_label', '@formTwig/flexy_form_theme.html.twig') -}}
    {%- endif -%}
{%- endblock form_label -%}

{# Help is rendered inline in the BO label; let Flexy handle it on the front. #}
{%- block form_help -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
    {%- else -%}
        {{- block('form_help', '@formTwig/flexy_form_theme.html.twig') -}}
    {%- endif -%}
{%- endblock -%}

{%- block form_row -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        <div{% with { attr: row_attr|merge({class: (row_attr.class|default('') ~ ' mb-3')|trim}) } %}{{ block('attributes', 'form_div_layout.html.twig') }}{% endwith %}>
            {{- form_label(form) -}}
            {{- form_widget(form) -}}
            {{- form_errors(form) -}}
        </div>
    {%- else -%}
        {{- block('form_row', '@formTwig/flexy_form_theme.html.twig') -}}
    {%- endif -%}
{%- endblock form_row -%}

{%- block checkbox_widget -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        {%- set attr = attr|merge({class: (attr.class|default('') ~ ' form-check-input')|trim}) -%}
        <input type="checkbox" {{ block('widget_attributes', 'form_div_layout.html.twig') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %}>
    {%- else -%}
        {{- block('checkbox_widget', 'bootstrap_5_layout.html.twig') -}}
    {%- endif -%}
{%- endblock checkbox_widget -%}

{%- block checkbox_row -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        <div{% with { attr: row_attr|merge({class: (row_attr.class|default('') ~ ' form-check mb-3')|trim}) } %}{{ block('attributes', 'form_div_layout.html.twig') }}{% endwith %}>
            {{- form_widget(form) -}}
            {{- block('checkbox_label') -}}
            {{- form_errors(form) -}}
        </div>
    {%- else -%}
        {{- block('form_row', 'form_div_layout.html.twig') -}}
    {%- endif -%}
{%- endblock checkbox_row -%}

{%- block checkbox_label -%}
    {%- if app is defined and app.request and app.request.pathInfo starts with '/admin' -%}
        {% if label is not same as(false) -%}
            {%- set label_attr = label_attr|merge({for: id, class: (label_attr.class|default('') ~ ' form-check-label')|trim}) -%}
            {%- if label is empty -%}
                {%- if label_format is not empty -%}
                    {%- set label = label_format|replace({'%name%': name, '%id%': id}) -%}
                {%- else -%}
                    {%- set label = name|humanize -%}
                {%- endif -%}
            {%- endif -%}
            <label{% with { attr: label_attr } %}{{ block('attributes', 'form_div_layout.html.twig') }}{% endwith %}>{{ translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) }}</label>
        {%- endif -%}
    {%- else -%}
        {{- block('checkbox_radio_label', 'bootstrap_5_layout.html.twig') -}}
    {%- endif -%}
{%- endblock checkbox_label -%}
