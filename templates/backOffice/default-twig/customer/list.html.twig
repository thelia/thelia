{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Customers'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}customers-list{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ 'Customers'|trans }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('customer.top') }}

    <div class="container-fluid" data-testid="customers-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0">{{ 'Customers'|trans }} <span class="badge bg-secondary ms-2" data-testid="customers-count">{{ total }}</span></h1>
            {% if is_granted('CREATE', 'admin.customer') %}
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#customer-create-modal" data-testid="customer-create-button">
                    <i class="bi bi-plus-lg" aria-hidden="true"></i>
                    {{ 'Add a new customer'|trans }}
                </button>
            {% endif %}
        </div>

        <form method="get" action="{{ path('admin.customers') }}" class="row g-2 mb-3" data-testid="customers-search-form">
            <div class="col-md-9">
                <input type="search" name="q" value="{{ current_search }}" class="form-control" placeholder="{{ 'Search by reference, name or email'|trans }}" data-testid="customers-search-input">
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-outline-primary flex-grow-1" data-testid="customers-search-submit">
                    <i class="bi bi-search" aria-hidden="true"></i> {{ 'Search'|trans }}
                </button>
                {% if current_search %}
                    <a href="{{ path('admin.customers') }}" class="btn btn-outline-secondary" data-testid="customers-search-clear">
                        {{ 'Reset'|trans }}
                    </a>
                {% endif %}
            </div>
        </form>

        {{ component('BoDataTable', {
            id: 'customers',
            columns: [
                column('ref', 'Reference'|trans),
                column('lastname', 'Last name'|trans),
                column('firstname', 'First name'|trans),
                column('email', 'Email'|trans),
                column('registration_date', 'Registration date'|trans),
                column_actions('_actions', 'Actions'|trans),
            ],
            rows: rows,
            emptyMessage: 'No customer found.'|trans,
        }) }}

        {% if pages > 1 %}
            <nav aria-label="{{ 'Customers pagination'|trans }}" class="mt-3" data-testid="customers-pagination">
                <ul class="pagination justify-content-center">
                    {% for n in 1..pages %}
                        <li class="page-item {% if n == current_page %}active{% endif %}">
                            <a class="page-link" href="{{ path('admin.customers', { page: n, q: current_search }) }}">{{ n }}</a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>
        {% endif %}
    </div>

    {{ safe_hook('customer.bottom') }}

    {% include '@BackOfficeDefaultTwig/customer/_customer_create_modal.html.twig' %}
    {% include '@BackOfficeDefaultTwig/customer/_customer_delete_modal.html.twig' %}
{% endblock %}
