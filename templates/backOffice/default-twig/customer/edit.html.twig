{% extends '@BackOfficeDefaultTwig/base.html.twig' %}

{% block title %}{{ 'Edit customer'|trans({}, 'bo.default-twig') }}{% endblock %}
{% block body_testid %}customer-edit{% endblock %}

{% block breadcrumb %}
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin.home') }}">{{ 'Home'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('admin.customers') }}">{{ 'Customers'|trans }}</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ customer.firstname }} {{ customer.lastname }}</li>
        </ol>
    </nav>
{% endblock %}

{% block content %}
    {{ safe_hook('customer-edit.top', { customer_id: customer.id }) }}

    <div class="container-fluid" data-testid="customer-edit-page">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="h3 mb-0" data-testid="customer-edit-title">
                {{ 'Edit customer'|trans }}: <span class="text-muted">{{ customer.firstname }} {{ customer.lastname }}</span>
                <small class="text-secondary ms-2">{{ customer.ref }}</small>
            </h1>
        </div>

        <div class="card">
            <div class="card-body">
                {{ form_start(form, {
                    action: path('admin.customer.update.process'),
                    method: 'post',
                    attr: { 'data-testid': 'customer-edit-form' },
                }) }}
                    <input type="hidden" name="customer_id" value="{{ customer.id }}">
                    {% include '@BackOfficeDefaultTwig/customer/_customer_form_fields.html.twig' with { form: form } only %}

                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a href="{{ path('admin.customers') }}" class="btn btn-outline-secondary" data-testid="customer-edit-cancel">
                            {{ 'Cancel'|trans }}
                        </a>
                        <button type="submit" class="btn btn-primary" data-testid="customer-edit-submit">
                            <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Save'|trans }}
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
            <div class="card-footer text-muted small">
                {{ 'Registered on %date'|trans({ '%date': customer.createdAt ? customer.createdAt|format_datetime('medium', 'short') : '—' }) }}
            </div>
        </div>

        <div class="card mt-4" data-testid="customer-addresses-section">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>{{ 'Addresses'|trans }} <span class="badge bg-secondary ms-1">{{ addresses|length }}</span></span>
                {% if is_granted('CREATE', 'admin.address') %}
                    <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#customer-address-create-modal" data-testid="customer-address-create-button">
                        <i class="bi bi-plus-lg" aria-hidden="true"></i> {{ 'Add a new address'|trans }}
                    </button>
                {% endif %}
            </div>
            <div class="card-body">
                {% if addresses is empty %}
                    <p class="text-muted mb-0">{{ 'No address registered for this customer.'|trans }}</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0" data-testid="customer-addresses-table">
                            <thead class="table-light">
                                <tr>
                                    <th>{{ 'Label'|trans }}</th>
                                    <th>{{ 'Name'|trans }}</th>
                                    <th>{{ 'Address'|trans }}</th>
                                    <th class="text-end">{{ 'Actions'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for addr in addresses %}
                                    <tr data-testid="customer-address-row" data-address-id="{{ addr.id }}">
                                        <td>
                                            {{ addr.label }}
                                            {% if addr.is_default %}<span class="badge bg-success ms-1">{{ 'Default'|trans }}</span>{% endif %}
                                        </td>
                                        <td>{{ addr.firstname }} {{ addr.lastname }}</td>
                                        <td class="text-muted small">{{ addr.address }}</td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <a href="{{ path('admin.address.update.view', { address_id: addr.id }) }}" class="btn btn-outline-primary" data-testid="customer-address-edit">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                {% if not addr.is_default and is_granted('UPDATE', 'admin.address') %}
                                                    <form method="post" action="{{ path('admin.address.makeItDefault') }}?_token={{ assignToken() }}" class="d-inline">
                                                        <input type="hidden" name="address_id" value="{{ addr.id }}">
                                                        <button type="submit" class="btn btn-outline-success" title="{{ 'Set as default'|trans }}" data-testid="customer-address-default">
                                                            <i class="bi bi-star"></i>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                                {% if is_granted('DELETE', 'admin.address') %}
                                                    <form method="post" action="{{ path('admin.address.delete') }}?_token={{ assignToken() }}" class="d-inline" onsubmit="return confirm('{{ 'Delete this address?'|trans|e('js') }}');">
                                                        <input type="hidden" name="address_id" value="{{ addr.id }}">
                                                        <button type="submit" class="btn btn-outline-danger" title="{{ 'Delete'|trans }}" data-testid="customer-address-delete">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                {% endif %}
                                            </div>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {% if address_create_form is defined and is_granted('CREATE', 'admin.address') %}
        {% include '@BackOfficeDefaultTwig/customer/_customer_address_create_modal.html.twig' %}
    {% endif %}

    {{ safe_hook('customer-edit.bottom', { customer_id: customer.id }) }}
{% endblock %}
