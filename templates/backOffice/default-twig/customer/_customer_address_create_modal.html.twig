<div class="modal fade" id="customer-address-create-modal" tabindex="-1" aria-labelledby="customer-address-create-modal-title" aria-hidden="true" data-testid="customer-address-create-modal">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            {{ form_start(address_create_form, {
                action: path('admin.address.create'),
                method: 'post',
                attr: { 'data-testid': 'customer-address-create-form' },
            }) }}
            <div class="modal-header">
                <h2 class="modal-title h5" id="customer-address-create-modal-title">{{ 'Add a new address'|trans }}</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-8">{{ form_row(address_create_form.label) }}</div>
                    <div class="col-md-4">{{ form_row(address_create_form.title) }}</div>
                    <div class="col-md-6">{{ form_row(address_create_form.firstname) }}</div>
                    <div class="col-md-6">{{ form_row(address_create_form.lastname) }}</div>
                    <div class="col-12">{{ form_row(address_create_form.company) }}</div>
                    <div class="col-12">{{ form_row(address_create_form.address1) }}</div>
                    <div class="col-12">{{ form_row(address_create_form.address2) }}</div>
                    <div class="col-12">{{ form_row(address_create_form.address3) }}</div>
                    <div class="col-md-4">{{ form_row(address_create_form.zipcode) }}</div>
                    <div class="col-md-8">{{ form_row(address_create_form.city) }}</div>
                    <div class="col-12">{{ form_row(address_create_form.country) }}</div>
                    <div class="col-md-6">{{ form_row(address_create_form.phone) }}</div>
                    <div class="col-md-6">{{ form_row(address_create_form.cellphone) }}</div>
                </div>
            </div>
            <div class="modal-footer">
                {{ form_widget(address_create_form.customer_id) }}
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="submit" class="btn btn-primary" data-testid="customer-address-create-submit">
                    <i class="bi bi-check2" aria-hidden="true"></i> {{ 'Add address'|trans }}
                </button>
            </div>
            {{ form_end(address_create_form, { render_rest: false }) }}
        </div>
    </div>
</div>
