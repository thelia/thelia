{# Back-office sidebar — mirrors the Smarty `includes/main-menu.html`:
   one static entry per section, gated by an ACL check, with hook_block
   children so modules can append their own links. Section names, hooks
   and ACL resources are kept iso with the Smarty template. #}

{% set current_route = app.request.attributes.get('_route')|default('') %}
{% set current_path = app.request.pathInfo|default('') %}

{% macro is_section(current_path, prefixes) %}
    {%- for prefix in prefixes -%}
        {%- if current_path starts with prefix -%}1{%- endif -%}
    {%- endfor -%}
{% endmacro %}
{% import _self as nav %}

<aside class="bo-side-nav d-none d-md-flex flex-column" data-testid="bo-main-nav" aria-label="{{ 'Main navigation'|trans }}">
    <a class="bo-side-nav__header" href="{{ path('admin.home') }}" aria-label="Thelia">
        {% include '@BackOfficeDefaultTwig/_thelia_logo.html.twig' with { variant: 'light', height: '32' } only %}
    </a>

    {{ safe_hook('main.before-top-menu', { location: 'before_top_menu' }) }}

    <nav class="bo-side-nav__sections flex-grow-1">
        <ul class="nav nav-pills flex-column mb-auto">
            <li class="nav-item">
                <a href="{{ path('admin.home') }}" class="nav-link {{ current_path == '/admin' or current_path == '/admin/home' ? 'active' : '' }}" data-testid="bo-nav-home">
                    <i class="bi bi-house-door me-2" aria-hidden="true"></i>
                    {{ 'Home'|trans }}
                </a>
            </li>

            {% if is_granted('VIEW', 'admin.customer') %}
                {% set active = nav.is_section(current_path, ['/admin/customer']) %}
                {% set hookFragments = hook_block('main.top-menu-customer', { fields: 'id,class,url,title' }) %}
                <li class="nav-item" data-testid="bo-nav-customer">
                    <a href="#bo-nav-customer-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                        <i class="bi bi-people me-2" aria-hidden="true"></i>
                        {{ 'Customers'|trans }}
                        <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                    </a>
                    <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-customer-collapse">
                        <li><a class="nav-link" href="{{ path('admin.customers') }}">{{ 'Customers'|trans }}</a></li>
                        {% for fragment in hookFragments %}
                            <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.order') %}
                {% set active = nav.is_section(current_path, ['/admin/order']) %}
                <li class="nav-item" data-testid="bo-nav-order">
                    <a href="#bo-nav-order-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                        <i class="bi bi-cart3 me-2" aria-hidden="true"></i>
                        {{ 'Orders'|trans }}
                        <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                    </a>
                    <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-order-collapse">
                        <li><a class="nav-link" href="{{ path('admin.order.list') }}">{{ 'All orders'|trans }}</a></li>
                        {% for fragment in hook_block('main.top-menu-order', { fields: 'id,class,url,title' }) %}
                            <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.category') %}
                {% set active = nav.is_section(current_path, ['/admin/catalog', '/admin/categories', '/admin/products']) %}
                {% set hookFragments = hook_block('main.top-menu-catalog', { fields: 'id,class,url,title' }) %}
                <li class="nav-item" data-testid="bo-nav-catalog">
                    <a href="#bo-nav-catalog-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                        <i class="bi bi-collection me-2" aria-hidden="true"></i>
                        {{ 'Catalog'|trans }}
                        <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                    </a>
                    <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-catalog-collapse">
                        <li><a class="nav-link" href="{{ path('admin.categories.default') }}">{{ 'Categories'|trans }}</a></li>
                        <li><a class="nav-link" href="{{ path('admin.products.default') }}">{{ 'Products'|trans }}</a></li>
                        {% for fragment in hookFragments %}
                            <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.folder') %}
                {% set active = nav.is_section(current_path, ['/admin/folder', '/admin/content']) %}
                {% set hookFragments = hook_block('main.top-menu-content', { fields: 'id,class,url,title' }) %}
                <li class="nav-item" data-testid="bo-nav-folder">
                    {% if hookFragments|length > 0 %}
                        <a href="#bo-nav-folder-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                            <i class="bi bi-folder2-open me-2" aria-hidden="true"></i>
                            {{ 'Folders'|trans }}
                            <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                        </a>
                        <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-folder-collapse">
                            <li><a class="nav-link" href="{{ path('admin.folders.default') }}">{{ 'Folders'|trans }}</a></li>
                            {% for fragment in hookFragments %}
                                <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <a href="{{ path('admin.folders.default') }}" class="nav-link {{ active ? 'active' : '' }}">
                            <i class="bi bi-folder2-open me-2" aria-hidden="true"></i>
                            {{ 'Folders'|trans }}
                        </a>
                    {% endif %}
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.tools') %}
                {% set active = nav.is_section(current_path, ['/admin/tools', '/admin/coupon', '/admin/sales', '/admin/export', '/admin/import', '/admin/brand']) %}
                <li class="nav-item" data-testid="bo-nav-tools">
                    <a href="#bo-nav-tools-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                        <i class="bi bi-wrench-adjustable me-2" aria-hidden="true"></i>
                        {{ 'Tools'|trans }}
                        <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                    </a>
                    <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-tools-collapse">
                        {% if is_granted('VIEW', 'admin.brand') %}
                            <li><a class="nav-link" href="{{ path('admin.brand.default') }}">{{ 'Brands'|trans }}</a></li>
                        {% endif %}
                        {% if is_granted('VIEW', 'admin.coupon') %}
                            <li><a class="nav-link" href="{{ path('admin.coupon.default') }}">{{ 'Coupons'|trans }}</a></li>
                        {% endif %}
                        <li><a class="nav-link" href="{{ path('admin.newsletter.default') }}">{{ 'Newsletter'|trans }}</a></li>
                        {% if is_granted('VIEW', 'admin.export') %}
                            <li><a class="nav-link" href="{{ path('export.list') }}">{{ 'Export'|trans }}</a></li>
                        {% endif %}
                        {% if is_granted('VIEW', 'admin.import') %}
                            <li><a class="nav-link" href="{{ path('import.list') }}">{{ 'Import'|trans }}</a></li>
                        {% endif %}
                        {% for fragment in hook_block('main.top-menu-tools', { fields: 'id,class,url,title' }) %}
                            <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.module') %}
                {% set active = nav.is_section(current_path, ['/admin/module', '/admin/module-hook']) %}
                {% set hookFragments = hook_block('main.top-menu-modules', { fields: 'id,class,url,title' }) %}
                <li class="nav-item" data-testid="bo-nav-modules">
                    <a href="#bo-nav-modules-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                        <i class="bi bi-puzzle me-2" aria-hidden="true"></i>
                        {{ 'Modules'|trans }}
                        <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                    </a>
                    <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-modules-collapse">
                        <li><a class="nav-link" href="/admin/modules">{{ 'Modules'|trans }}</a></li>
                        <li><a class="nav-link" href="/admin/module-hooks">{{ 'Hooks'|trans }}</a></li>
                        {% for fragment in hookFragments %}
                            <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                        {% endfor %}
                    </ul>
                </li>
            {% endif %}

            {% if is_granted('VIEW', 'admin.configuration') %}
                {% set active = nav.is_section(current_path, ['/admin/configuration', '/admin/order-status']) %}
                {% set hookFragments = hook_block('main.top-menu-configuration', { fields: 'id,class,url,title' }) %}
                <li class="nav-item" data-testid="bo-nav-configuration">
                    {% if hookFragments|length > 0 %}
                        <a href="#bo-nav-config-collapse" data-bs-toggle="collapse" aria-expanded="{{ active ? 'true' : 'false' }}" class="nav-link bo-side-nav__toggle {{ active ? 'active' : '' }}">
                            <i class="bi bi-gear me-2" aria-hidden="true"></i>
                            {{ 'Configuration'|trans }}
                            <i class="bi bi-chevron-right ms-auto bo-side-nav__chevron" aria-hidden="true"></i>
                        </a>
                        <ul class="nav flex-column collapse {{ active ? 'show' : '' }}" id="bo-nav-config-collapse">
                            <li><a class="nav-link" href="{{ path('admin.configuration.languages.default') }}">{{ 'Languages'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.currencies.default') }}">{{ 'Currencies'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.countries.default') }}">{{ 'Countries'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.states.default') }}">{{ 'States'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.customer-titles.default') }}">{{ 'Customer titles'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.messages.default') }}">{{ 'Messages'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.mailingSystem.default') }}">{{ 'Mailing system'|trans }}</a></li>
                            <li><a class="nav-link" href="{{ path('admin.configuration.variables.default') }}">{{ 'Variables'|trans }}</a></li>
                            {% for fragment in hookFragments %}
                                <li><a class="nav-link" href="{{ fragment.url }}"{% if fragment.id %} id="{{ fragment.id }}"{% endif %}>{{ fragment.title }}</a></li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <a href="/admin/configuration" class="nav-link {{ active ? 'active' : '' }}">
                            <i class="bi bi-gear me-2" aria-hidden="true"></i>
                            {{ 'Configuration'|trans }}
                        </a>
                    {% endif %}
                </li>
            {% endif %}

            {{ safe_hook('main.in-top-menu-items', { admin_current_location: current_route }) }}
        </ul>
    </nav>

    {{ safe_hook('main.topbar-bottom') }}
    {{ safe_hook('main.after-top-menu', { location: 'after_top_menu' }) }}
</aside>
